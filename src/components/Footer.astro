---
const year = new Date().getFullYear();
---

<footer id="contact" class="bg-ink text-cream py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      <div>
        <p class="font-serif text-2xl text-mango-300 mb-3">Mother's Gold Spice</p>
        <p class="text-sm text-cream/70 leading-relaxed">
          Small-batch mango pickle, hand-made in Bangalore.
        </p>
      </div>

      <div>
        <p class="text-xs uppercase tracking-widest text-mango-300 mb-4">Get in Touch</p>
        <a
          href="mailto:mothersgoldspice@gmail.com"
          class="text-cream hover:text-mango-300 transition"
        >
          mothersgoldspice@gmail.com
        </a>
      </div>

      <div>
        <p class="text-xs uppercase tracking-widest text-mango-300 mb-4">Follow Along</p>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="https://instagram.com/mothersgoldspice"
              target="_blank"
              rel="noopener"
              class="text-cream hover:text-mango-300 transition"
            >
              Instagram → @mothersgoldspice
            </a>
          </li>
          <li>
            <a
              href="https://x.com/mothergoldspice"
              target="_blank"
              rel="noopener"
              class="text-cream hover:text-mango-300 transition"
            >
              X → @mothergoldspice
            </a>
          </li>
          <li>
            <a
              href="https://youtube.com/@MothersGoldSpice"
              target="_blank"
              rel="noopener"
              class="text-cream hover:text-mango-300 transition"
            >
              YouTube → @MothersGoldSpice
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-cream/10 flex flex-col sm:flex-row justify-between text-xs text-cream/50">
      <p>© {year} Mother's Gold Spice. Made with love in Bangalore.</p>
      <p class="mt-2 sm:mt-0">All recipes are family secrets.</p>
    </div>
  </div>
</footer>
