---
---

<section id="top" class="relative min-h-screen flex items-center bg-gradient-to-br from-mango-50 via-cream to-mango-100 overflow-hidden">
  <div class="absolute inset-0 opacity-30 pointer-events-none">
    <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-mango-300 blur-3xl"></div>
    <div class="absolute -bottom-32 -left-32 w-96 h-96 rounded-full bg-spice-500 blur-3xl"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 pt-32 pb-20 grid md:grid-cols-2 gap-12 items-center">
    <div>
      <span class="inline-block px-3 py-1 rounded-full bg-spice-700/10 text-spice-700 text-xs font-medium tracking-wide uppercase mb-6">
        Hand-made in Bangalore
      </span>
      <h1 class="text-5xl md:text-6xl font-serif font-semibold text-ink leading-tight">
        The taste of <span class="text-spice-500 italic">home</span>,<br />
        in a jar.
      </h1>
      <p class="mt-6 text-lg text-ink/70 max-w-md leading-relaxed">
        Small-batch mango pickle, hand-made by a mother whose recipe has been
        loved by friends and family for decades. No preservatives. No shortcuts.
        Just sunshine, mustard, and time.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#buy"
          class="inline-flex items-center px-6 py-3 bg-spice-700 text-white rounded-full font-medium hover:bg-spice-500 transition shadow-lg shadow-spice-700/20"
        >
          Coming soon →
        </a>
        <a
          href="#story"
          class="inline-flex items-center px-6 py-3 border border-ink/20 text-ink rounded-full font-medium hover:bg-ink/5 transition"
        >
          Our story
        </a>
      </div>
    </div>

    <div class="relative">
      <div class="aspect-[3/4] rounded-3xl overflow-hidden bg-gradient-to-br from-mango-300 to-spice-500 shadow-2xl shadow-spice-700/30">
        <img
          src="/jar.jpg"
          alt="A jar of Mother's Gold Spice mango pickle"
          fetchpriority="high"
          decoding="async"
          class="w-full h-full object-cover"
        />
      </div>
      <div class="absolute -bottom-6 -left-6 bg-cream rounded-2xl px-5 py-3 shadow-xl border border-mango-100">
        <p class="text-xs uppercase tracking-wider text-ink/60">Made in</p>
        <p class="font-serif text-lg text-spice-700">Bangalore</p>
      </div>
    </div>
  </div>
</section>
