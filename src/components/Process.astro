---
const steps = [
  {
    n: "01",
    title: "The Tree",
    caption: "Mangoes ripening in the Bangalore sun. We wait for the right kind — tart, firm, just turning.",
    img: "/process/01-tree.jpg",
  },
  {
    n: "02",
    title: "The Harvest",
    caption: "Picked by hand, one at a time, with a long fruit-picker. No mechanical shaking, no bruising.",
    img: "/process/02-picker.jpg",
  },
  {
    n: "03",
    title: "The Sorting",
    caption: "A pan full of just-picked mangoes, sorted by hand. Only the best ones make it to the next step.",
    img: "/process/03-pan.jpg",
  },
  {
    n: "04",
    title: "Sun-Drying",
    caption: "Cut and laid out to dry in the open sun. No ovens, no preservatives — the way her mother taught her.",
    img: "/process/04-drying.jpg",
  },
];
---

<section id="process" class="py-24 bg-gradient-to-b from-mango-50 via-cream to-mango-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="block text-xs uppercase tracking-widest text-spice-500 font-medium mb-4">
        How It's Made
      </span>
      <h2 class="text-4xl md:text-5xl font-serif font-semibold mb-6 leading-tight">
        From the tree<br />
        <span class="italic text-spice-700">to your table.</span>
      </h2>
      <p class="text-lg text-ink/70 leading-relaxed">
        Every jar starts in our own backyard. No factory in between.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step) => (
        <article class="relative">
          <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-xl shadow-spice-700/20 bg-mango-100">
            <img
              src={step.img}
              alt={step.title}
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover"
            />
          </div>

          <div class="mt-5">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="font-serif text-spice-500 text-2xl">{step.n}</span>
              <h3 class="font-serif text-xl text-ink">{step.title}</h3>
            </div>
            <p class="text-sm text-ink/70 leading-relaxed">{step.caption}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
