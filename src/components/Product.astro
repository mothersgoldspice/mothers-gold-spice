---
---

<section id="product" class="py-24 bg-gradient-to-b from-cream to-mango-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div class="order-2 md:order-1">
        <div class="aspect-[4/5] rounded-3xl overflow-hidden bg-gradient-to-br from-mango-300 to-spice-500 shadow-2xl shadow-spice-700/30 p-8">
          <img
            src="/mango-jar.png"
            alt="Mother's Gold Spice mango pickle jar"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-contain drop-shadow-2xl"
          />
        </div>
      </div>

      <div class="order-1 md:order-2">
        <span class="block text-xs uppercase tracking-widest text-spice-500 font-medium mb-4">
          The Pickle
        </span>
        <h2 class="text-4xl md:text-5xl font-serif font-semibold mb-6 leading-tight">
          Mango Mustard Pickle
        </h2>
        <p class="text-lg text-ink/70 leading-relaxed mb-8">
          Tart raw mango, slow-cooked in mustard oil with a blend of roasted
          spices — mustard, fenugreek, garlic, red chili. Bold, deeply aromatic,
          and made to last on your shelf without a single preservative.
        </p>

        <div class="space-y-3 text-sm">
          <div class="flex justify-between border-b border-ink/10 pb-3">
            <span class="text-ink/60">Net weight</span>
            <span class="font-medium">250g / 500g jars</span>
          </div>
          <div class="flex justify-between border-b border-ink/10 pb-3">
            <span class="text-ink/60">Shelf life</span>
            <span class="font-medium">12 months unopened</span>
          </div>
          <div class="flex justify-between border-b border-ink/10 pb-3">
            <span class="text-ink/60">Ingredients</span>
            <span class="font-medium text-right">Raw mango, mustard oil, salt, spices</span>
          </div>
          <div class="flex justify-between pb-3">
            <span class="text-ink/60">Made in</span>
            <span class="font-medium">Bangalore, India</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
