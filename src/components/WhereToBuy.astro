---
---

<section id="buy" class="py-24 bg-mango-50">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <span class="block text-xs uppercase tracking-widest text-spice-500 font-medium mb-4">
      Where to Buy
    </span>
    <h2 class="text-4xl md:text-5xl font-serif font-semibold mb-6 leading-tight">
      Launching soon.
    </h2>
    <p class="text-lg text-ink/70 leading-relaxed max-w-2xl mx-auto mb-12">
      We're putting the finishing touches on our first batch and getting set up
      on Amazon. Leave us your email below and we'll let you know the moment
      the first jars are ready to ship.
    </p>

    <form class="max-w-md mx-auto flex flex-col sm:flex-row gap-3" onsubmit="event.preventDefault(); alert('Email signup coming soon — for now, reach us at mothersgoldspice@gmail.com');">
      <input
        type="email"
        placeholder="you@example.com"
        required
        class="flex-1 px-5 py-3 rounded-full border border-ink/15 bg-white focus:outline-none focus:border-spice-500 focus:ring-2 focus:ring-spice-500/20 transition"
      />
      <button
        type="submit"
        class="px-6 py-3 bg-spice-700 text-white rounded-full font-medium hover:bg-spice-500 transition shadow-lg shadow-spice-700/20"
      >
        Notify me
      </button>
    </form>

    <div class="mt-16 grid sm:grid-cols-2 gap-6 max-w-xl mx-auto">
      <div class="p-6 bg-white rounded-2xl border border-mango-100">
        <p class="font-serif text-lg text-ink mb-1">Amazon India</p>
        <p class="text-sm text-ink/60">Coming soon</p>
      </div>
      <div class="p-6 bg-white rounded-2xl border border-mango-100">
        <p class="font-serif text-lg text-ink mb-1">Direct from us</p>
        <p class="text-sm text-ink/60">Coming soon</p>
      </div>
    </div>
  </div>
</section>
