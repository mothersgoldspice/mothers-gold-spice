---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Mother's Gold Spice — Authentic Mango Pickle from Bangalore",
  description = "Small-batch mango pickle, hand-made in a Bangalore kitchen. The taste of home, in a jar.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mothersgoldspice.com" />
    <meta property="og:site_name" content="Mother's Gold Spice" />
    <meta property="og:image" content="https://mothersgoldspice.com/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Mother's Gold Spice — small-batch mango pickle from Bangalore" />
    <meta property="og:locale" content="en_IN" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://mothersgoldspice.com/og-image.jpg" />
    <meta name="twitter:image:alt" content="Mother's Gold Spice — small-batch mango pickle from Bangalore" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
