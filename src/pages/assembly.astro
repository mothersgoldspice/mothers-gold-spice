---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Interactive Assembly — Mother's Gold Spice" description="Step through how a Mother's Gold Spice jar is assembled, one part at a time.">
  <main class="bg-cream min-h-screen pb-16">
    <header class="max-w-6xl mx-auto px-6 pt-12 pb-8 border-b border-ink/10">
      <p class="text-xs uppercase tracking-widest text-spice-500 font-medium mb-3">Internal preview · assembly simulator</p>
      <h1 class="font-serif text-3xl md:text-4xl text-ink mb-3">How a jar is built — step by step</h1>
      <p class="text-ink/60 max-w-2xl text-sm">Click each step on the right in order. Watch the part fly in and snap into place. End-to-end this is the same sequence the production line follows for every 250 g jar.</p>
      <a href="/label-preview" class="inline-block mt-4 text-xs text-spice-500 hover:text-spice-700 underline">← Back to Label Preview</a>
    </header>

    <section id="assembly-shell" class="max-w-6xl mx-auto px-6 mt-8">
      <!-- 3D Viewer — parts live INSIDE the scene as miniature components -->
      <div id="assembly-stage" class="relative rounded-3xl overflow-hidden" style="background: radial-gradient(ellipse at center, #fff8eb 0%, #ffe9c2 100%);">
        <div
          id="assembly3d-container"
          class="w-full relative"
          style="aspect-ratio: 16 / 10; cursor: grab; touch-action: none;"
        ></div>

        <button
          type="button"
          id="assembly-immersive"
          class="absolute top-4 right-4 px-3 py-1.5 text-xs rounded-full bg-white/85 border border-ink/15 text-ink hover:bg-white transition flex items-center gap-1.5 backdrop-blur-sm z-10"
          aria-label="Toggle full-screen demo mode"
        >
          <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
            <path d="M2 6 V2 H6 M14 6 V2 H10 M2 10 V14 H6 M14 10 V14 H10"/>
          </svg>
          <span data-immersive-label>Immersive</span>
        </button>

        <div id="assembly-status" class="absolute top-4 left-4 max-w-[60%] px-3 py-2 rounded-full bg-white/85 backdrop-blur-sm border border-ink/10 text-[12px] text-ink/80 italic z-10">
          Click any floating part to snap it onto the jar.
        </div>
      </div>

      <!-- Bottom controls -->
      <div class="flex flex-wrap items-center justify-center gap-3 mt-5">
        <button id="assembly-play" class="px-5 py-2.5 bg-spice text-white text-sm rounded-full hover:bg-spice-700 transition">▶ Play full assembly</button>
        <button id="assembly-reset" class="px-5 py-2.5 bg-white border border-ink/10 text-ink text-sm rounded-full hover:bg-mango-50 transition">↻ Reset</button>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  /* Parts tray cards */
  .assembly-part-card {
    background: #fff;
    border: 1px solid rgba(42, 26, 16, 0.08);
    border-radius: 16px;
    padding: 12px 10px 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    box-shadow: 0 2px 5px rgba(42, 26, 16, 0.04);
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.2s, opacity 0.25s;
    position: relative;
  }
  .assembly-part-card:hover { transform: translateY(-2px); box-shadow: 0 6px 14px rgba(42, 26, 16, 0.08); }
  .part-icon-wrap {
    width: 70px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, #fffaf0 0%, #fff3dc 100%);
    border-radius: 10px;
    padding: 4px;
    transition: transform 0.5s cubic-bezier(0.25, 1.4, 0.5, 1);
  }
  .part-icon { width: 100%; height: 100%; display: block; }
  .part-meta { text-align: center; line-height: 1.2; }
  .part-num {
    display: inline-block;
    background: #ffe9c2;
    color: #7a1f10;
    font-size: 9px;
    font-weight: 700;
    padding: 1px 6px;
    border-radius: 999px;
    margin-bottom: 2px;
  }
  .part-name { display: block; font-size: 11px; color: #2a1a10; font-weight: 500; }
  .part-apply {
    width: 100%;
    padding: 5px 8px;
    background: #7a1f10;
    color: #fff;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    transition: background 0.2s, transform 0.1s;
  }
  .part-apply:hover { background: #5a1408; }
  .part-apply:active { transform: scale(0.96); }
  .part-apply:disabled { background: #d0c8bd; cursor: not-allowed; }
  /* States */
  .assembly-part-card.is-active {
    border-color: #7a1f10;
    box-shadow: 0 0 0 2px rgba(122, 31, 16, 0.18), 0 6px 14px rgba(42, 26, 16, 0.1);
  }
  .assembly-part-card.is-active .part-icon-wrap {
    transform: scale(1.1);
  }
  .assembly-part-card.is-done {
    opacity: 0.55;
  }
  .assembly-part-card.is-done .part-apply {
    background: #1e7a1e;
    cursor: default;
  }
  .assembly-part-card.is-done .part-apply::before { content: "✓ "; }

  /* Immersive (full-screen demo) */
  body.assembly-immersive-active {
    overflow: hidden;
  }
  body.assembly-immersive-active #assembly-shell {
    position: fixed;
    inset: 0;
    max-width: none;
    width: 100vw;
    height: 100vh;
    padding: 16px 18px;
    margin: 0;
    z-index: 1000;
    background: linear-gradient(180deg, #fff8eb 0%, #ffe9c2 100%);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  body.assembly-immersive-active #assembly-stage {
    flex: 1;
    border-radius: 20px;
  }
  body.assembly-immersive-active #assembly-parts-tray {
    margin-bottom: 0;
  }
  body.assembly-immersive-active .assembly-part-card {
    padding: 10px 8px 8px;
  }
  body.assembly-immersive-active .part-icon-wrap {
    width: 60px;
    height: 50px;
  }

  @media (max-width: 720px) {
    #assembly-parts-tray { grid-template-columns: repeat(5, 1fr); gap: 6px; }
    .assembly-part-card { padding: 8px 5px 6px; }
    .part-icon-wrap { width: 50px; height: 40px; }
    .part-name { font-size: 9px; }
    .part-apply { font-size: 10px; padding: 4px 6px; }
  }
</style>

<script>
