  import { RoomEnvironment } from "three/addons/environments/RoomEnvironment.js";

  // --- Build label SVG (one continuous strip: back | seam | front) ---
  // Texture aspect 4:1 maps cleanly onto a cylinder.
  const labelSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 360" width="1440" height="360">
