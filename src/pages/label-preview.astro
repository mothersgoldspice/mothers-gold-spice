      <text x="0" y="36" font-size="12">Raw Mango (60%), Mustard Oil (25%), Salt,</text>
      <text x="0" y="52" font-size="12">Spices (Mustard, Fenugreek, Red Chilli,</text>
      <text x="0" y="68" font-size="12">Turmeric, Asafoetida).</text>

      <text x="0" y="94" font-family="'Fraunces', Georgia, serif" font-weight="700" font-size="13" letter-spacing="1.5" fill="#7a1f10">ALLERGEN</text>
      <text x="0" y="114" font-size="12">Contains Mustard.</text>

      <text x="0" y="140" font-family="'Fraunces', Georgia, serif" font-weight="700" font-size="13" letter-spacing="1.5" fill="#7a1f10">NUTRITION (per 100g)</text>
      <g font-size="11">
        <text x="0" y="158">Energy</text><text x="280" y="158" text-anchor="end" font-variant-numeric="tabular-nums">168 kcal</text>
        <text x="0" y="174">Protein</text><text x="280" y="174" text-anchor="end" font-variant-numeric="tabular-nums">1.2 g</text>
        <text x="0" y="190">Carbohydrates</text><text x="280" y="190" text-anchor="end" font-variant-numeric="tabular-nums">8.4 g</text>
        <text x="0" y="206">Total Fat</text><text x="280" y="206" text-anchor="end" font-variant-numeric="tabular-nums">14.8 g</text>
        <text x="0" y="222">Sodium</text><text x="280" y="222" text-anchor="end" font-variant-numeric="tabular-nums">2,840 mg</text>
      </g>

      <text x="0" y="248" font-family="'Fraunces', Georgia, serif" font-weight="700" font-size="13" letter-spacing="1.5" fill="#7a1f10">STORAGE</text>
      <text x="0" y="266" font-size="12">Cool, dry place. Refrigerate after opening.</text>
      <text x="0" y="282" font-size="12">Use a clean, dry spoon.</text>

      <line x1="0" y1="298" x2="400" y2="298" stroke="#2a1a10" stroke-opacity="0.15" stroke-width="0.6"/>

      <g transform="translate(0, 312)">
        <text x="0" y="0" font-family="'Fraunces', Georgia, serif" font-weight="700" font-size="9" letter-spacing="0.6" fill="#7a1f10">FSSAI</text>
        <text x="0" y="13" font-size="10" font-variant-numeric="tabular-nums">10012345000123</text>

        <text x="140" y="0" font-family="'Fraunces', Georgia, serif" font-weight="700" font-size="9" letter-spacing="0.6" fill="#7a1f10">BATCH</text>
        <text x="140" y="13" font-size="10" font-variant-numeric="tabular-nums">MGS-2026-04-001</text>

        <text x="290" y="0" font-family="'Fraunces', Georgia, serif" font-weight="700" font-size="9" letter-spacing="0.6" fill="#7a1f10">MFG / BB</text>
        <text x="290" y="13" font-size="9.5" font-variant-numeric="tabular-nums">04/2026–04/2027</text>
      </g>
    </g>

    <!-- SEAM at x = 716 to 720 (the glue overlap on the physical jar) -->
    <rect x="716" y="0" width="4" height="360" fill="#7a1f10" fill-opacity="0.05"/>

    <!-- FRONT PANEL: x = 720 to 1440 (center at x = 1080) -->
    <g transform="translate(720, 0)" font-family="'Inter', 'Helvetica Neue', sans-serif" fill="#2a1a10">
      <g transform="translate(360, 52)">
        <line x1="-105" y1="0" x2="-90" y2="0" stroke="#7a1f10" stroke-width="1"/>
        <text x="0" y="3" text-anchor="middle" font-size="11" letter-spacing="2.6" fill="#7a1f10" font-weight="600">HAND-MADE IN BANGALORE</text>
        <line x1="105" y1="0" x2="90" y2="0" stroke="#7a1f10" stroke-width="1"/>
      </g>

      <text x="360" y="104" text-anchor="middle" font-family="'Fraunces', Georgia, serif" font-style="italic" font-weight="600" font-size="30" fill="#2a1a10">Mother's Gold Spice</text>

      <g transform="translate(360, 124)">
        <line x1="-52" y1="0" x2="-14" y2="0" stroke="#e08712" stroke-width="1.5"/>
        <path d="M 0 -7 C 5 -3 5 4 0 7 C -5 4 -5 -3 0 -7 Z" fill="#e08712"/>
        <line x1="14" y1="0" x2="52" y2="0" stroke="#e08712" stroke-width="1.5"/>
      </g>

      <text x="360" y="186" text-anchor="middle" font-family="'Fraunces', Georgia, serif" font-weight="600" font-size="56" fill="#7a1f10">Mango Pickle</text>

      <text x="360" y="214" text-anchor="middle" font-family="'Fraunces', Georgia, serif" font-style="italic" font-size="20" fill="#2a1a10" fill-opacity="0.7">in Mustard Oil</text>

      <g transform="translate(360, 250)">
        <line x1="-170" y1="-13" x2="170" y2="-13" stroke="#7a1f10" stroke-opacity="0.3" stroke-width="1"/>
        <line x1="-170" y1="13" x2="170" y2="13" stroke="#7a1f10" stroke-opacity="0.3" stroke-width="1"/>
        <text x="-80" y="5" text-anchor="middle" font-weight="600" font-size="11" letter-spacing="1.8" fill="#7a1f10">NO PRESERVATIVES</text>
        <text x="0" y="5" text-anchor="middle" font-size="14" fill="#7a1f10" fill-opacity="0.4">·</text>
        <text x="80" y="5" text-anchor="middle" font-weight="600" font-size="11" letter-spacing="1.8" fill="#7a1f10">NO ADDITIVES</text>
      </g>

      <!-- Bottom row: NET WT | VEG | MRP, packed tight around centre x = 360 -->
      <g transform="translate(360, 318)">
        <g transform="translate(-115, 0)">
          <text x="0" y="0" text-anchor="middle" font-size="10" letter-spacing="1.2" fill="#7a1f10" font-weight="600">NET WT.</text>
          <text x="0" y="22" text-anchor="middle" font-family="'Fraunces', Georgia, serif" font-weight="600" font-size="22" fill="#2a1a10">250g</text>
        </g>

        <rect x="-17" y="-10" width="34" height="34" fill="none" stroke="#1e7a1e" stroke-width="2.2"/>
        <circle cx="0" cy="7" r="10" fill="#1e7a1e"/>

        <g transform="translate(115, 0)">
          <text x="0" y="0" text-anchor="middle" font-size="10" letter-spacing="1.2" fill="#7a1f10" font-weight="600">MRP</text>
          <text x="0" y="22" text-anchor="middle" font-family="'Fraunces', Georgia, serif" font-weight="600" font-size="22" fill="#2a1a10">₹449</text>
        </g>
      </g>
    </g>
  </svg>`;

  async function init() {
    await document.fonts.ready;

    const container = document.getElementById("jar3d-container");
    if (!container) return;

    const w = container.clientWidth;
    const h = container.clientHeight;

    const scene = new THREE.Scene();
    scene.background = null;

    const camera = new THREE.PerspectiveCamera(30, w / h, 0.1, 100);
    camera.position.set(0, 0.5, 9);

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(w, h);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    // Neutral tone mapping preserves the bagasse cream and spice-red colors faithfully.
    // ACES (the previous choice) made the cream look bright-white by amplifying highlights.
    renderer.toneMapping = THREE.NeutralToneMapping;
    renderer.toneMappingExposure = 1.0;
    container.appendChild(renderer.domElement);

    // Environment map for realistic metal/glass reflections
    const pmrem = new THREE.PMREMGenerator(renderer);
    const envTexture = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;
    scene.environment = envTexture;

    // Lighting — balanced for honest cream-paper reproduction (key dropped from 1.8 → 1.0)
    const ambient = new THREE.AmbientLight(0xffffff, 0.35);
    scene.add(ambient);
    const hemi = new THREE.HemisphereLight(0xfff5e0, 0x6a4a28, 0.45);
    scene.add(hemi);
    const key = new THREE.DirectionalLight(0xffffff, 1.0);
    scene.add(key);
    const fill = new THREE.DirectionalLight(0xfff4d6, 0.2);
    scene.add(fill);
    const rim = new THREE.DirectionalLight(0xffe5b8, 0.2);
    scene.add(rim);

    // Materials we'll mutate from the control panel
    let glassMat: THREE.MeshPhysicalMaterial | null = null;
    let labelMat: THREE.MeshStandardMaterial | null = null;
    let goldMat: THREE.MeshStandardMaterial | null = null;

    // Base values — what gets multiplied by the "brightness" slider
    const BASE = { ambient: 0.35, hemi: 0.45, key: 1.0, fill: 0.2, rim: 0.2 };
    const COOL = new THREE.Color(0xffffff);
    const WARM = new THREE.Color(0xffd5a0);
    const FILL_COOL = new THREE.Color(0xfff4d6);
    const FILL_WARM = new THREE.Color(0xffc78a);

    function applyLighting(s: any) {
      if (!s) return;
      const L = s.lights || {};
      const on = (key: string) => L[key] !== false;
      const tint = COOL.clone().lerp(WARM, s.warmth);
      const fillTint = FILL_COOL.clone().lerp(FILL_WARM, s.warmth);
      ambient.intensity = (on("ambient") ? BASE.ambient : 0) * s.brightness;
      ambient.color.copy(tint);
      hemi.intensity = (on("hemi") ? BASE.hemi : 0) * s.brightness;
      key.intensity = (on("key") ? BASE.key : 0) * s.brightness;
      key.color.copy(tint);
      fill.intensity = (on("fill") ? BASE.fill : 0) * s.brightness;
      fill.color.copy(fillTint);
      rim.intensity = (on("rim") ? BASE.rim : 0) * s.brightness;
      rim.color.copy(tint);
      scene.environment = on("envmap") ? envTexture : null;
      if (glassMat) glassMat.envMapIntensity = s.env;
      if (goldMat) goldMat.envMapIntensity = s.env;
      if (labelMat) labelMat.envMapIntensity = s.label;
      // Scene exposure — master dim/bright for the whole render. Drag to 0 for total darkness.
      renderer.toneMappingExposure = typeof s.exposure === "number" ? s.exposure : 1.0;
    }

    window.addEventListener("mgs-lighting-change", (e: any) => applyLighting(e.detail));

    // Helper: SVG string → CanvasTexture
    function svgToCanvasTexture(svg: string, w: number, h: number, fillBg: string | null): Promise<THREE.CanvasTexture> {
      return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = "anonymous";
        img.onload = () => {
          const canvas = document.createElement("canvas");
          canvas.width = w;
          canvas.height = h;
          const ctx = canvas.getContext("2d");
          if (!ctx) return reject(new Error("no ctx"));
          if (fillBg) {
            ctx.fillStyle = fillBg;
            ctx.fillRect(0, 0, w, h);
          } else {
            ctx.clearRect(0, 0, w, h);
          }
          ctx.drawImage(img, 0, 0, w, h);
          const tex = new THREE.CanvasTexture(canvas);
          tex.colorSpace = THREE.SRGBColorSpace;
          tex.anisotropy = renderer.capabilities.getMaxAnisotropy();
          resolve(tex);
        };
        img.onerror = reject;
        img.src = "data:image/svg+xml;charset=utf-8," + encodeURIComponent(svg);
      });
    }

    Promise.all([
      svgToCanvasTexture(labelSvg, 2880, 720, "#fbf6ec"),
      svgToCanvasTexture(jarCapDecalSvg, 1024, 1024, null),
    ]).then(([labelTexture, capDecalTexture]) => {
      labelTexture.wrapS = THREE.RepeatWrapping;
      // Front-panel center sits at texture u = 0.75. Cylinder u = 0 is the +Z (camera-
      // facing) side. offset.x = 0.75 lands the front centre directly facing the camera.
      labelTexture.offset.set(0.75, 0);
      buildJar(labelTexture, capDecalTexture);
    }).catch((err) => console.error("Jar textures failed", err));

    let controls: any = null;

    function buildJar(labelTexture: THREE.CanvasTexture, capDecalTexture: THREE.CanvasTexture) {
      const jar = new THREE.Group();

      // Clear glass body — full transmission and thickness for a proper thick-glass
      // look. `ior` is dropped from real-glass (1.5) to 1.05 so the curved lower wall
      // no longer refracts the front label downward into a ghost band. Thickness gives
      // it volume, clearcoat gives it surface sheen; no attenuation so it stays bright.
      glassMat = new THREE.MeshPhysicalMaterial({
        color: 0xfffaf0,
        roughness: 0.05,
        metalness: 0,
        transmission: 1.0,
        thickness: 0.6,
        ior: 1.05,
        transparent: true,
        opacity: 1,
        side: THREE.DoubleSide,
        clearcoat: 0.6,
        clearcoatRoughness: 0.06,
      });

      // Body profile (lathed around Y axis): rounded base, straight panel, shoulder
      // taper to neck. Bottom corner + shoulder are built as quarter-circle arcs
      // (instead of 3-point bevels) so they read as soft curves rather than chunky chamfers.
      const bodyProfile: THREE.Vector2[] = [
        new THREE.Vector2(0, -1.30),
        new THREE.Vector2(0.80, -1.30),  // flat base ends, bottom curve starts
      ];
      // Bottom corner: quarter-circle radius 0.20, centre (0.80, -1.10).
      // Sweeps from (0.80, -1.30) at angle −π/2 up to (1.00, -1.10) at angle 0.
      {
        const r = 0.20, cx = 0.80, cy = -1.10, segs = 16;
        for (let i = 1; i <= segs; i++) {
          const ang = -Math.PI / 2 + (Math.PI / 2) * (i / segs);
          bodyProfile.push(new THREE.Vector2(cx + r * Math.cos(ang), cy + r * Math.sin(ang)));
        }
      }
      bodyProfile.push(new THREE.Vector2(1.00, 1.08));   // straight body, top end
      // Shoulder: quarter-circle radius 0.17, centre (0.83, 1.08).
      // Sweeps from (1.00, 1.08) at angle 0 up to (0.83, 1.25) at angle π/2.
      {
        const r = 0.17, cx = 0.83, cy = 1.08, segs = 14;
        for (let i = 1; i <= segs; i++) {
          const ang = (Math.PI / 2) * (i / segs);
          bodyProfile.push(new THREE.Vector2(cx + r * Math.cos(ang), cy + r * Math.sin(ang)));
        }
      }
      bodyProfile.push(new THREE.Vector2(0.83, 1.28));   // short neck (hidden by cap)
      const body = new THREE.Mesh(new THREE.LatheGeometry(bodyProfile, 160), glassMat);
      jar.add(body);

      // Label wrap — thin cylinder on the straight body panel.
      // FrontSide-only: a real paper label only renders on its outer face. Using DoubleSide
      // made the inner face of the cylinder visible through the transparent glass,
      // producing a ghosted mirror copy of the front-panel content on the body.
      labelMat = new THREE.MeshStandardMaterial({
        map: labelTexture,
        side: THREE.FrontSide,
        roughness: 0.85,
        metalness: 0,
        envMapIntensity: 0.25,
      });
      const labelMesh = new THREE.Mesh(
        new THREE.CylinderGeometry(1.018, 1.018, 1.55, 128, 1, true),
        labelMat
      );
      labelMesh.position.y = -0.05;
      jar.add(labelMesh);

      // Warm champagne-gold tinplate cap (matte/satin finish — not mirror chrome).
      // DoubleSide makes the top disc render no matter which way LatheGeometry winds it.
      goldMat = new THREE.MeshStandardMaterial({
        color: 0xc9a96e,
        roughness: 0.42,
        metalness: 0.85,
        side: THREE.DoubleSide,
      });
      const capProfile = [
        new THREE.Vector2(0, 1.85),
        new THREE.Vector2(0.78, 1.85),    // top flat ends (smaller flat → softer look)
      ];
      // Top corner: quarter-circle radius 0.18, centred at (0.78, 1.67).
      // Goes from (0.78, 1.85) over the top edge down to (0.96, 1.67) on the side wall.
      const rTop = 0.18, cTopX = 0.78, cTopY = 1.67;
      const topSegs = 14;
      for (let i = 1; i <= topSegs; i++) {
        const a = (Math.PI / 2) * (i / topSegs);
        capProfile.push(new THREE.Vector2(cTopX + rTop * Math.sin(a), cTopY + rTop * Math.cos(a)));
      }
      capProfile.push(new THREE.Vector2(0.96, 1.36));   // straight side wall

      // Bottom corner: smaller rounded chamfer (radius 0.06) so the cap-to-neck edge
      // isn't a hard 90°.
      const rBot = 0.06, cBotX = 0.90, cBotY = 1.36;
      const botSegs = 6;
      for (let i = 1; i <= botSegs; i++) {
        const a = (Math.PI / 2) * (i / botSegs);
        capProfile.push(new THREE.Vector2(cBotX + rBot * Math.cos(a), cBotY - rBot * Math.sin(a)));
      }
      capProfile.push(new THREE.Vector2(0.86, 1.30));   // close to neck radius
      const cap = new THREE.Mesh(new THREE.LatheGeometry(capProfile, 128), goldMat);
      jar.add(cap);

      // v2 cap-top decal (foil-stamped brand mark sitting just above the cap surface)
      const capDecalMat = new THREE.MeshStandardMaterial({
        map: capDecalTexture,
        transparent: true,
        alphaTest: 0.02,
        roughness: 0.4,
        metalness: 0.6,
        side: THREE.DoubleSide,
      });
      const capDecal = new THREE.Mesh(new THREE.CircleGeometry(0.74, 96), capDecalMat);
      capDecal.rotation.x = -Math.PI / 2;
      capDecal.position.y = 1.851; // just above the cap top to avoid z-fighting
      jar.add(capDecal);

      jar.position.y = -0.25;
      scene.add(jar);

      // Apply current lighting now that the materials exist
      if ((window as any).mgsLighting) applyLighting((window as any).mgsLighting);

      controls = new OrbitControls(camera, renderer.domElement);
      controls.enablePan = false;
      controls.enableZoom = true;
      controls.minDistance = 4;
      controls.maxDistance = 18;
      // Allow full vertical rotation so the user can inspect top + bottom
      controls.minPolarAngle = 0.01;
      controls.maxPolarAngle = Math.PI - 0.01;
      controls.autoRotate = true;
      controls.autoRotateSpeed = 1.2;
      controls.rotateSpeed = 0.7;
      controls.target.set(0, 0, 0);
      controls.update();

      // Stop auto-rotate on user interaction; resume after idle
      let idleTimer: ReturnType<typeof setTimeout>;
      const resetIdle = () => {
        if (controls) controls.autoRotate = false;
        clearTimeout(idleTimer);
        idleTimer = setTimeout(() => {
          if (controls) controls.autoRotate = true;
        }, 2500);
      };
      controls.addEventListener("start", resetIdle);
    }

    // Reusable vectors so the per-frame light positioning doesn't allocate
    const _forward = new THREE.Vector3();
    const _right = new THREE.Vector3();
    const WORLD_UP = new THREE.Vector3(0, 1, 0);

    function positionLightsRelativeToCamera() {
      _forward.subVectors((controls && controls.target) || new THREE.Vector3(), camera.position).normalize();
      _right.crossVectors(_forward, WORLD_UP).normalize();
      // Key partway between camera and jar, offset to viewer's right + up — so the light
      // direction has both a "side" and a "forward toward jar" component. The camera-facing
      // surface then receives a real right→left brightness gradient.
      key.position.copy(camera.position).multiplyScalar(0.4)
        .addScaledVector(_right, 10).addScaledVector(WORLD_UP, 3);
      fill.position.copy(camera.position).multiplyScalar(0.4)
        .addScaledVector(_right, -7).addScaledVector(WORLD_UP, 2);
      rim.position.copy(camera.position).multiplyScalar(-0.6).addScaledVector(WORLD_UP, 3);
      // Rotate the environment map to follow the camera. Without this, the metal cap's
      // reflections come from a world-fixed virtual room, so the highlight appears stuck
      // to the jar surface and "rotates with it" from the viewer's perspective.
      scene.environmentRotation.y = Math.atan2(camera.position.x, camera.position.z);
    }

    function animate() {
      requestAnimationFrame(animate);
      if (controls) controls.update();
      positionLightsRelativeToCamera();
      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener("resize", () => {
      const w = container.clientWidth;
      const h = container.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    });
  }

  init();
</script>

<script>
  // ============================================================
  // Cap-only preview (section 4) — gold cap with v2 brand mark
  // ============================================================
  import * as THREE from "three";
  import { OrbitControls } from "three/addons/controls/OrbitControls.js";
  import { RoomEnvironment } from "three/addons/environments/RoomEnvironment.js";

  // Brand-mark SVG that would be foil-stamped on the cap top.
  // Spice-red foil on gold tinplate.
  const capDecalSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" width="500" height="500">
    <defs>
      <path id="capTopArc" d="M 90,265 A 160,160 0 0 1 410,265" fill="none"/>
    </defs>

    <!-- Outer ring -->
    <circle cx="250" cy="250" r="225" fill="none" stroke="#7a1f10" stroke-width="1" stroke-opacity="0.5"/>
    <circle cx="250" cy="250" r="218" fill="none" stroke="#7a1f10" stroke-width="0.6" stroke-opacity="0.35"/>

    <!-- Top arched: italic serif wordmark -->
    <text font-family="'Fraunces', Georgia, serif" font-style="italic" font-size="34" font-weight="600" fill="#7a1f10">
      <textPath href="#capTopArc" startOffset="50%" text-anchor="middle">Mother's Gold Spice</textPath>
    </text>

    <!-- Divider with small accent (sits just above the leaf as a single stacked unit) -->
    <g transform="translate(250, 240)">
      <line x1="-46" y1="0" x2="-14" y2="0" stroke="#7a1f10" stroke-width="1.4"/>
      <path d="M 0,-7 C 5,-3 5,4 0,7 C -5,4 -5,-3 0,-7 Z" fill="#7a1f10"/>
      <line x1="14" y1="0" x2="46" y2="0" stroke="#7a1f10" stroke-width="1.4"/>
    </g>

    <!-- Centre: lanceolate leaf — placed so divider+leaf together centre between wordmark + tagline -->
    <g transform="translate(250, 300)">
      <path d="M 0,-46
               C 9,-38 17,-22 18,-2
               C 17,18 9,34 0,46
               C -9,34 -17,18 -18,-2
               C -17,-22 -9,-38 0,-46 Z"
            fill="#7a1f10"/>
    </g>

    <!-- Bottom: shelf-friendly tagline (no backstory needed) -->
    <text x="250" y="412" text-anchor="middle" font-family="'Inter', sans-serif" font-size="13" font-weight="600" letter-spacing="3.0" fill="#7a1f10">A FAMILY RECIPE</text>

    <!-- Decorative dots -->
    <circle cx="250" cy="92" r="2.5" fill="#7a1f10"/>
    <circle cx="80" cy="250" r="1.8" fill="#7a1f10"/>
    <circle cx="420" cy="250" r="1.8" fill="#7a1f10"/>
  </svg>`;

  async function initCap() {
    await document.fonts.ready;

    const container = document.getElementById("cap3d-container");
    if (!container) return;

    const w = container.clientWidth;
    const h = container.clientHeight;

    const scene = new THREE.Scene();
    scene.background = null;

    const camera = new THREE.PerspectiveCamera(32, w / h, 0.1, 100);
    camera.position.set(0, 3.2, 3.6);

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(w, h);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.toneMapping = THREE.NeutralToneMapping;
    renderer.toneMappingExposure = 1.0;
    container.appendChild(renderer.domElement);

    // Environment map gives the gold metal proper reflections from every angle
    const pmrem = new THREE.PMREMGenerator(renderer);
    const envTexture = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;
    scene.environment = envTexture;

    const ambient = new THREE.AmbientLight(0xffffff, 0.35);
    scene.add(ambient);
    const hemi = new THREE.HemisphereLight(0xfff5e0, 0x6a4a28, 0.45);
    scene.add(hemi);
    const key = new THREE.DirectionalLight(0xffffff, 1.0);
    scene.add(key);
    const fill = new THREE.DirectionalLight(0xfff4d6, 0.2);
    scene.add(fill);
    const rim = new THREE.DirectionalLight(0xffe5b8, 0.2);
    scene.add(rim);

    let goldMat: THREE.MeshStandardMaterial | null = null;

    const BASE = { ambient: 0.35, hemi: 0.45, key: 1.0, fill: 0.2, rim: 0.2 };
    const COOL = new THREE.Color(0xffffff);
    const WARM = new THREE.Color(0xffd5a0);
    const FILL_COOL = new THREE.Color(0xfff4d6);
    const FILL_WARM = new THREE.Color(0xffc78a);

    function applyLighting(s: any) {
      if (!s) return;
      const L = s.lights || {};
      const on = (key: string) => L[key] !== false;
      const tint = COOL.clone().lerp(WARM, s.warmth);
      const fillTint = FILL_COOL.clone().lerp(FILL_WARM, s.warmth);
      ambient.intensity = (on("ambient") ? BASE.ambient : 0) * s.brightness;
      ambient.color.copy(tint);
      hemi.intensity = (on("hemi") ? BASE.hemi : 0) * s.brightness;
      key.intensity = (on("key") ? BASE.key : 0) * s.brightness;
      key.color.copy(tint);
      fill.intensity = (on("fill") ? BASE.fill : 0) * s.brightness;
      fill.color.copy(fillTint);
      rim.intensity = (on("rim") ? BASE.rim : 0) * s.brightness;
      rim.color.copy(tint);
      scene.environment = on("envmap") ? envTexture : null;
      if (goldMat) goldMat.envMapIntensity = s.env;
      renderer.toneMappingExposure = typeof s.exposure === "number" ? s.exposure : 1.0;
    }

    window.addEventListener("mgs-lighting-change", (e: any) => applyLighting(e.detail));

    const dataUrl = "data:image/svg+xml;charset=utf-8," + encodeURIComponent(capDecalSvg);
    const img = new Image();
    img.crossOrigin = "anonymous";

    img.onload = () => {
      const canvas = document.createElement("canvas");
      canvas.width = 1024;
      canvas.height = 1024;
      const ctx = canvas.getContext("2d");
      if (!ctx) return;
      ctx.clearRect(0, 0, 1024, 1024);
      ctx.drawImage(img, 0, 0, 1024, 1024);

      const decalTexture = new THREE.CanvasTexture(canvas);
      decalTexture.colorSpace = THREE.SRGBColorSpace;
      decalTexture.anisotropy = renderer.capabilities.getMaxAnisotropy();

      buildCap(decalTexture);
    };
    img.onerror = (err) => console.error("Cap decal load failed", err);
    img.src = dataUrl;

    let controls: any = null;

    function buildCap(decalTex: THREE.CanvasTexture) {
      const group = new THREE.Group();

      // Same gold material as the jar's cap. DoubleSide so the top disc renders properly.
      goldMat = new THREE.MeshStandardMaterial({
        color: 0xc9a96e,
        roughness: 0.42,
        metalness: 0.85,
        side: THREE.DoubleSide,
      });

      // Cap profile — rounded top corner (14-segment quarter-circle), rounded bottom
      // chamfer. Same geometry as section 3 jar3d so the v2 mockup matches the v1 cap.
      const capProfile: THREE.Vector2[] = [
        new THREE.Vector2(0, 1.85),
        new THREE.Vector2(0.78, 1.85),
      ];
      {
        const r = 0.18, cx = 0.78, cy = 1.67, segs = 14;
        for (let i = 1; i <= segs; i++) {
          const a = (Math.PI / 2) * (i / segs);
          capProfile.push(new THREE.Vector2(cx + r * Math.sin(a), cy + r * Math.cos(a)));
        }
      }
      capProfile.push(new THREE.Vector2(0.96, 1.36));
      {
        const r = 0.06, cx = 0.90, cy = 1.36, segs = 6;
        for (let i = 1; i <= segs; i++) {
          const a = (Math.PI / 2) * (i / segs);
          capProfile.push(new THREE.Vector2(cx + r * Math.cos(a), cy - r * Math.sin(a)));
        }
      }
      capProfile.push(new THREE.Vector2(0.86, 1.30));
      const cap = new THREE.Mesh(new THREE.LatheGeometry(capProfile, 128), goldMat);
      group.add(cap);

      // Internal thread — matching GPI 63/2030 helix inside the cap, visible from
      // below when the camera tilts under the cap. Same spec as section 5 seal view:
      //   2.5 turns, 6 mm pitch, single-lead, right-hand, crest at radius 0.92.
      class HelixCurve extends THREE.Curve<THREE.Vector3> {
        constructor(
          private radius: number,
          private yStart: number,
          private yEnd: number,
          private turns: number,
        ) { super(); }
        getPoint(t: number, target = new THREE.Vector3()) {
          const angle = this.turns * Math.PI * 2 * t;
          const y = this.yStart + (this.yEnd - this.yStart) * t;
          return target.set(this.radius * Math.cos(angle), y, this.radius * Math.sin(angle));
        }
      }
      const capThreadCurve = new HelixCurve(0.92, 1.33, 1.61, 2.5);
      const capThreadGeo = new THREE.TubeGeometry(capThreadCurve, 360, 0.020, 14, false);
      const capThread = new THREE.Mesh(capThreadGeo, goldMat);
      group.add(capThread);

      // EPE liner — cream foam disc bonded inside the cap's underside top. Compresses
      // against the jar rim when the cap is torqued down.
      const linerMat = new THREE.MeshStandardMaterial({
        color: 0xf5e8d0,
        roughness: 0.95,
        metalness: 0,
      });
      const linerGeo = new THREE.CylinderGeometry(0.82, 0.82, 0.06, 64);
      const liner = new THREE.Mesh(linerGeo, linerMat);
      liner.position.y = 1.66; // tucked against the cap's inner ceiling
      group.add(liner);

      // Brand-mark decal disc — sits just above the cap top to avoid z-fighting
      const decalMat = new THREE.MeshStandardMaterial({
        map: decalTex,
        transparent: true,
        alphaTest: 0.02,
        roughness: 0.4,
        metalness: 0.6,
        side: THREE.DoubleSide,
      });
      const decal = new THREE.Mesh(new THREE.CircleGeometry(0.78, 96), decalMat);
      decal.rotation.x = -Math.PI / 2;
      decal.position.y = 1.851;
      group.add(decal);

      // Centre the group near the camera's target
      group.position.y = -1.55;
      scene.add(group);

      // Apply current lighting now that the material exists
      if ((window as any).mgsLighting) applyLighting((window as any).mgsLighting);

      controls = new OrbitControls(camera, renderer.domElement);
      controls.enablePan = false;
      controls.enableZoom = true;
      controls.minDistance = 2.5;
      controls.maxDistance = 10;
      controls.minPolarAngle = 0.01;
      controls.maxPolarAngle = Math.PI - 0.01;
      controls.autoRotate = true;
      controls.autoRotateSpeed = 1.4;
      controls.rotateSpeed = 0.7;
      controls.target.set(0, 0, 0);
      controls.update();

      let idleTimer: ReturnType<typeof setTimeout>;
      const resetIdle = () => {
        if (controls) controls.autoRotate = false;
        clearTimeout(idleTimer);
        idleTimer = setTimeout(() => {
          if (controls) controls.autoRotate = true;
        }, 2500);
      };
      controls.addEventListener("start", resetIdle);
    }

    const _forward = new THREE.Vector3();
    const _right = new THREE.Vector3();
    const WORLD_UP = new THREE.Vector3(0, 1, 0);

    function positionLightsRelativeToCamera() {
      _forward.subVectors((controls && controls.target) || new THREE.Vector3(), camera.position).normalize();
      _right.crossVectors(_forward, WORLD_UP).normalize();
      // Place key partway between camera and jar, offset to viewer's right + up.
      key.position.copy(camera.position).multiplyScalar(0.4)
        .addScaledVector(_right, 10).addScaledVector(WORLD_UP, 3);
      fill.position.copy(camera.position).multiplyScalar(0.4)
        .addScaledVector(_right, -7).addScaledVector(WORLD_UP, 2);
      rim.position.copy(camera.position).multiplyScalar(-0.6).addScaledVector(WORLD_UP, 3);
      scene.environmentRotation.y = Math.atan2(camera.position.x, camera.position.z);
    }

    function animate() {
      requestAnimationFrame(animate);
      if (controls) controls.update();
      positionLightsRelativeToCamera();
      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener("resize", () => {
      const w = container.clientWidth;
      const h = container.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    });
  }

  initCap();
</script>

<script>
  // ============================================================
  // Seal exploded view (section 5) — the 3 layers separated
  // vertically so each is visible: cap, foil seal, shrink sleeve.
  // ============================================================
  import * as THREE from "three";
  import { OrbitControls } from "three/addons/controls/OrbitControls.js";
  import { RoomEnvironment } from "three/addons/environments/RoomEnvironment.js";

  // SVG for the v2 cap-top brand mark — same artwork as section 4's cap close-up.
  const capDecalSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" width="500" height="500">
    <defs>
      <path id="sealCapTopArc" d="M 90,265 A 160,160 0 0 1 410,265" fill="none"/>
    </defs>
    <circle cx="250" cy="250" r="225" fill="none" stroke="#7a1f10" stroke-width="1" stroke-opacity="0.5"/>
    <circle cx="250" cy="250" r="218" fill="none" stroke="#7a1f10" stroke-width="0.6" stroke-opacity="0.35"/>
    <text font-family="'Fraunces', Georgia, serif" font-style="italic" font-size="34" font-weight="600" fill="#7a1f10">
      <textPath href="#sealCapTopArc" startOffset="50%" text-anchor="middle">Mother's Gold Spice</textPath>
    </text>
    <g transform="translate(250, 240)">
      <line x1="-46" y1="0" x2="-14" y2="0" stroke="#7a1f10" stroke-width="1.4"/>
      <path d="M 0,-7 C 5,-3 5,4 0,7 C -5,4 -5,-3 0,-7 Z" fill="#7a1f10"/>
      <line x1="14" y1="0" x2="46" y2="0" stroke="#7a1f10" stroke-width="1.4"/>
    </g>
    <g transform="translate(250, 300)">
      <path d="M 0,-46
               C 9,-38 17,-22 18,-2
               C 17,18 9,34 0,46
               C -9,34 -17,18 -18,-2
               C -17,-22 -9,-38 0,-46 Z"
            fill="#7a1f10"/>
    </g>
    <text x="250" y="412" text-anchor="middle" font-family="'Inter', sans-serif" font-size="13" font-weight="600" letter-spacing="3.0" fill="#7a1f10">A FAMILY RECIPE</text>
    <circle cx="250" cy="92" r="2.5" fill="#7a1f10"/>
    <circle cx="80" cy="250" r="1.8" fill="#7a1f10"/>
    <circle cx="420" cy="250" r="1.8" fill="#7a1f10"/>
  </svg>`;

  // SVG for the tamper band — a thin 6mm-tall joint band (NOT a full shrink sleeve).
  // Sits over the cap-to-neck seam only; cap sides stay visible. Tears on first twist.
  const shrinkSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 2048 96" width="2048" height="96">
    <rect x="0" y="0" width="2048" height="96" fill="#7a1f10"/>
    <g font-family="'Inter', sans-serif" font-size="34" font-weight="600" fill="#fbf6ec" text-anchor="middle" dominant-baseline="middle" letter-spacing="3">
      <text x="170"  y="50">SEALED</text>
      <text x="510"  y="50">· MOTHER'S GOLD SPICE ·</text>
      <text x="1024" y="50">SMALL BATCH</text>
      <text x="1538" y="50">· MOTHER'S GOLD SPICE ·</text>
      <text x="1878" y="50">SEALED</text>
    </g>
    <g stroke="#fbf6ec" stroke-opacity="0.35" stroke-width="1">
      <line x1="0" y1="14" x2="2048" y2="14"/>
      <line x1="0" y1="82" x2="2048" y2="82"/>
    </g>
  </svg>`;

  // SVG for the foil seal — printed face shown with "PEEL HERE" tab and brand mark
  const foilSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="512" height="512">
    <defs>
      <radialGradient id="foilGrad" cx="50%" cy="40%" r="60%">
        <stop offset="0%" stop-color="#fff4d6"/>
        <stop offset="65%" stop-color="#dcc28c"/>
        <stop offset="100%" stop-color="#b89758"/>
      </radialGradient>
      <path id="foilArc" d="M 106,275 A 150,150 0 0 1 406,275" fill="none"/>
    </defs>
    <circle cx="256" cy="256" r="248" fill="url(#foilGrad)"/>
    <circle cx="256" cy="256" r="240" fill="none" stroke="#7a1f10" stroke-width="1" stroke-opacity="0.5"/>
    <text font-family="'Fraunces', Georgia, serif" font-style="italic" font-size="44" font-weight="600" fill="#7a1f10">
      <textPath href="#foilArc" startOffset="50%" text-anchor="middle">Mother's Gold Spice</textPath>
    </text>
    <text x="256" y="285" text-anchor="middle" font-family="'Inter', sans-serif" font-size="38" font-weight="700" letter-spacing="6" fill="#7a1f10">SEALED</text>
    <text x="256" y="320" text-anchor="middle" font-family="'Inter', sans-serif" font-size="16" font-weight="500" letter-spacing="4" fill="#7a1f10" opacity="0.85">FOR FRESHNESS</text>
    <text x="256" y="420" text-anchor="middle" font-family="'Inter', sans-serif" font-size="14" font-weight="600" letter-spacing="3" fill="#7a1f10" opacity="0.7">↑ PEEL HERE ↑</text>
  </svg>`;

  function svgToTexture(svg: string, w = 1024, h = w): Promise<THREE.CanvasTexture> {
    // NOTE: must use a data URL (not Blob URL). Blob URLs sometimes silently fail to
    // draw to a 2D canvas — symptoms: no error, no image, getImageData returns 0,0,0,0.
    // Data URLs encoded via encodeURIComponent are the proven-working path here (see
    // jar3d's svgToCanvasTexture and cap3d's inline loader).
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.crossOrigin = "anonymous";
      img.onload = () => {
        const cv = document.createElement("canvas");
        cv.width = w; cv.height = h;
        const ctx = cv.getContext("2d");
        if (!ctx) return reject(new Error("no ctx"));
        ctx.clearRect(0, 0, w, h);
        ctx.drawImage(img, 0, 0, w, h);
        resolve(new THREE.CanvasTexture(cv));
      };
      img.onerror = (err) => reject(err);
      img.src = "data:image/svg+xml;charset=utf-8," + encodeURIComponent(svg);
    });
  }

  async function initSeal() {
    await document.fonts.ready;
    const container = document.getElementById("seal3d-container");
    if (!container) return;
    const w = container.clientWidth;
    const h = container.clientHeight;

    const scene = new THREE.Scene();
    scene.background = null;
    const camera = new THREE.PerspectiveCamera(28, w / h, 0.1, 100);
    camera.position.set(2.0, 3.5, 9.5);

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(w, h);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.toneMapping = THREE.NeutralToneMapping;
    renderer.toneMappingExposure = 1.0;
    container.appendChild(renderer.domElement);

    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

    scene.add(new THREE.AmbientLight(0xffffff, 0.45));
    scene.add(new THREE.HemisphereLight(0xfff5e0, 0x6a4a28, 0.45));
    const key = new THREE.DirectionalLight(0xffffff, 1.0);
    key.position.set(6, 8, 6);
    scene.add(key);
    const fill = new THREE.DirectionalLight(0xfff4d6, 0.25);
    fill.position.set(-6, 3, 4);
    scene.add(fill);

    // ---- GROUP: full assembly ----
    const assembly = new THREE.Group();

    // Reuse: jar body (same profile as section 3 jar3d) ----------------------
    const glassMat = new THREE.MeshPhysicalMaterial({
      color: 0xfffaf0,
      roughness: 0.05,
      metalness: 0,
      transmission: 1.0,
      thickness: 0.6,
      ior: 1.05,
      transparent: true,
      opacity: 1,
      side: THREE.DoubleSide,
      clearcoat: 0.6,
      clearcoatRoughness: 0.06,
    });
    const bodyProfile: THREE.Vector2[] = [
      new THREE.Vector2(0, -1.30),
      new THREE.Vector2(0.80, -1.30),
    ];
    {
      const r = 0.20, cx = 0.80, cy = -1.10, segs = 16;
      for (let i = 1; i <= segs; i++) {
        const ang = -Math.PI / 2 + (Math.PI / 2) * (i / segs);
        bodyProfile.push(new THREE.Vector2(cx + r * Math.cos(ang), cy + r * Math.sin(ang)));
      }
    }
    bodyProfile.push(new THREE.Vector2(1.00, 1.08));
    {
      const r = 0.17, cx = 0.83, cy = 1.08, segs = 14;
      for (let i = 1; i <= segs; i++) {
        const ang = (Math.PI / 2) * (i / segs);
        bodyProfile.push(new THREE.Vector2(cx + r * Math.cos(ang), cy + r * Math.sin(ang)));
      }
    }
    // GLASS NECK — modelled to GPI 63/2030 finish (the Indian + ISO 9100 standard for
    // 63 mm wide-mouth food jars). Dimensions below scale so 1 unit ≈ 31.5 mm.
    //
    //   T (thread OD)  ≈ 62 mm  → radius 0.985 → thread crest at 0.875 (neck OD 0.85
    //                                            + thread height 0.025)
    //   E (root dia.)  ≈ 60 mm  → radius 0.85   → straight neck wall
    //   S (rim OD)     ≈ 66 mm  → radius 1.05   → outward flare for seal land
    //   I (mouth ID)   ≈ 50 mm  → radius 0.79
    //   Sealing surface height ≈ 1.5 mm flat ring on top of rim
    //   Total neck height (shoulder → rim top) ≈ 12 mm
    //
    // The lathe profile builds the OUTER silhouette: straight neck → outward bevel →
    // flat sealing rim → step in to mouth ID. Threads are added as a separate helical
    // mesh below.
    bodyProfile.push(new THREE.Vector2(0.85, 1.62));   // top of straight neck wall
    bodyProfile.push(new THREE.Vector2(0.86, 1.625));  // tiny outward bevel
    bodyProfile.push(new THREE.Vector2(0.88, 1.63));   // rim shoulder out
    bodyProfile.push(new THREE.Vector2(0.88, 1.66));   // top of rim OD
    bodyProfile.push(new THREE.Vector2(0.79, 1.66));   // mouth ID (foil seals here)
    const body = new THREE.Mesh(new THREE.LatheGeometry(bodyProfile, 160), glassMat);
    assembly.add(body);

    // ---- NECK THREADS (external) — GPI 63/2030 continuous single-lead --------
    // Built as a TubeGeometry traced along a helical curve. The thread CENTRELINE sits
    // AT the neck wall radius (0.85) — so the inner half of the tube is buried inside
    // the neck glass and the outer half protrudes. With the same `glassMat` reference
    // shared with the body, both meshes refract+reflect identically and the thread
    // visually fuses to the neck instead of looking like a wrapped wire.
    //   pitch ≈ 4 mm (one turn rises 4 mm along the jar axis at our 1u≈31.5mm scale)
    //   thread height (crest – root) ≈ 0.8 mm = 0.025 units (tube radius)
    //   turns: 2.5 (hand-tight in <1 full rotation)
    //   start: just above the shoulder (y = 1.31)
    //   end:   ~1 mm below the rim base   (y = 1.59)
    class HelixCurve extends THREE.Curve<THREE.Vector3> {
      constructor(
        private radius: number,
        private yStart: number,
        private yEnd: number,
        private turns: number,
        private direction: 1 | -1 = 1
      ) { super(); }
      getPoint(t: number, target = new THREE.Vector3()) {
        const angle = this.direction * this.turns * Math.PI * 2 * t;
        const y = this.yStart + (this.yEnd - this.yStart) * t;
        return target.set(this.radius * Math.cos(angle), y, this.radius * Math.sin(angle));
      }
    }
    const neckThreadCurve = new HelixCurve(0.86, 1.31, 1.59, 2.5, 1);
    const neckThreadGeo = new THREE.TubeGeometry(neckThreadCurve, 360, 0.028, 16, false);
    const neckThread = new THREE.Mesh(neckThreadGeo, glassMat);
    assembly.add(neckThread);

    // ---- LAYER 2: induction foil seal ----------------------------------------
    // In real life it bonds flat to the jar rim (top sealing surface at y = 1.66).
    // For the exploded view, lift it well above the rim so it reads as a distinct disc.
    const foilTex = await svgToTexture(foilSvg, 1024);
    foilTex.colorSpace = THREE.SRGBColorSpace;
    const foilTopMat = new THREE.MeshStandardMaterial({
      map: foilTex,
      metalness: 0.85,
      roughness: 0.25,
    });
    const foilSideMat = new THREE.MeshStandardMaterial({
      color: 0xc9aa6a,
      metalness: 0.95,
      roughness: 0.3,
    });
    // CylinderGeometry materials: [side, top, bottom]. Foil OD matches rim OD (0.88).
    const foilGeo = new THREE.CylinderGeometry(0.88, 0.88, 0.02, 96, 1, false);
    const foil = new THREE.Mesh(foilGeo, [foilSideMat, foilTopMat, foilSideMat]);
    foil.position.y = 2.30;
    assembly.add(foil);

    // ---- LAYER 1: cap with visible EPE liner + internal threads --------------
    // Lifted further above so the foil is between jar and cap.
    const goldMat = new THREE.MeshStandardMaterial({
      color: 0xc9a96e,
      roughness: 0.42,
      metalness: 0.85,
      side: THREE.DoubleSide,
    });
    const capProfile: THREE.Vector2[] = [
      new THREE.Vector2(0, 1.85),
      new THREE.Vector2(0.78, 1.85),
    ];
    {
      const r = 0.18, cx = 0.78, cy = 1.67, segs = 14;
      for (let i = 1; i <= segs; i++) {
        const a = (Math.PI / 2) * (i / segs);
        capProfile.push(new THREE.Vector2(cx + r * Math.sin(a), cy + r * Math.cos(a)));
      }
    }
    capProfile.push(new THREE.Vector2(0.96, 1.36));
    {
      const r = 0.06, cx = 0.90, cy = 1.36, segs = 6;
      for (let i = 1; i <= segs; i++) {
        const a = (Math.PI / 2) * (i / segs);
        capProfile.push(new THREE.Vector2(cx + r * Math.cos(a), cy - r * Math.sin(a)));
      }
    }
    capProfile.push(new THREE.Vector2(0.86, 1.30));
    const capLift = 2.55;
    const capGroup = new THREE.Group();
    const cap = new THREE.Mesh(new THREE.LatheGeometry(capProfile, 128), goldMat);
    capGroup.add(cap);

    // v2 cap-top brand mark — foil-stamped artwork sitting just above the cap dome.
    const capDecalTex = await svgToTexture(capDecalSvg, 1024);
    capDecalTex.colorSpace = THREE.SRGBColorSpace;
    const capDecalMat = new THREE.MeshStandardMaterial({
      map: capDecalTex,
      transparent: true,
      alphaTest: 0.02,
      roughness: 0.4,
      metalness: 0.6,
      side: THREE.DoubleSide,
    });
    const capDecal = new THREE.Mesh(new THREE.CircleGeometry(0.74, 96), capDecalMat);
    capDecal.rotation.x = -Math.PI / 2;
    capDecal.position.y = 1.851; // sit just above the cap top to avoid z-fighting
    capGroup.add(capDecal);

    // CAP INNER THREADS — matching helical ridge on the cap's inside wall.
    // Inverse direction so it mates with the jar neck thread (right-hand convention).
    // Radius 0.92 sits inside cap wall (0.96) by ~1.3 mm = 0.04 units.
    // Y range matches the neck thread range but shifted by 0.02 vertical so cap+jar
    // engagement clamps with a residual half-turn of compression.
    const capThreadCurve = new HelixCurve(0.92, 1.33, 1.61, 2.5, 1);
    const capThreadGeo = new THREE.TubeGeometry(capThreadCurve, 360, 0.020, 14, false);
    const capThread = new THREE.Mesh(capThreadGeo, goldMat);
    capGroup.add(capThread);

    capGroup.position.y = capLift;
    assembly.add(capGroup);

    // EPE liner — in real life this is bonded inside the cap (factory-pressed). For
    // the exploded view, pull it out and float it as its own layer between the cap
    // and the foil so the user can clearly see all four parts that go into the seal:
    // cap → liner → foil → jar.
    const linerMat = new THREE.MeshStandardMaterial({
      color: 0xf5e8d0,
      roughness: 0.95,
      metalness: 0,
    });
    const linerGeo = new THREE.CylinderGeometry(0.84, 0.84, 0.06, 64);
    const liner = new THREE.Mesh(linerGeo, linerMat);
    liner.position.y = 3.05; // floating between foil (y=2.30) and cap bottom (y=3.85)
    assembly.add(liner);

    // ---- LAYER 3: tamper band (joint only, not a full sleeve) ----------------
    // A thin ~6mm-tall printed PET band that wraps the cap-to-neck seam ONLY,
    // leaving the gold cap surface fully visible. Tears the moment the cap is twisted —
    // tamper evidence for retail/quick-commerce shelves (Blinkit, modern trade).
    // In real life it sits at y=1.27 (just below cap bottom) to y=1.46 (overlapping
    // the top of the neck). For the exploded view, float it off to the side.
    const shrinkTex = await svgToTexture(shrinkSvg, 2048, 96);
    shrinkTex.colorSpace = THREE.SRGBColorSpace;
    shrinkTex.wrapS = THREE.RepeatWrapping;
    shrinkTex.repeat.x = 1;
    const shrinkMat = new THREE.MeshStandardMaterial({
      map: shrinkTex,
      roughness: 0.45,
      metalness: 0.0,
      side: THREE.DoubleSide,
    });
    const shrinkGeo = new THREE.CylinderGeometry(0.98, 0.98, 0.19, 96, 1, true);
    const shrink = new THREE.Mesh(shrinkGeo, shrinkMat);
    shrink.position.set(2.3, 1.6, 0); // off to the side, near the joint level
    shrink.rotation.y = -0.35;
    assembly.add(shrink);

    // Center the whole assembly vertically so the orbit feels balanced
    assembly.position.y = -1.0;
    scene.add(assembly);

    // ---- Dashed connector lines (visually link separated layers) -------------
    const connectorMat = new THREE.LineDashedMaterial({
      color: 0x7a1f10,
      dashSize: 0.08,
      gapSize: 0.06,
      transparent: true,
      opacity: 0.35,
    });
    const makeConnector = (y1: number, y2: number, x = 0) => {
      const geo = new THREE.BufferGeometry().setFromPoints([
        new THREE.Vector3(x, y1, 0),
        new THREE.Vector3(x, y2, 0),
      ]);
      const line = new THREE.Line(geo, connectorMat);
      line.computeLineDistances();
      return line;
    };
    // jar-rim → foil → liner → cap (all four parts on one stacked axis)
    assembly.add(makeConnector(1.67, 2.29));   // rim → foil
    assembly.add(makeConnector(2.31, 3.02));   // foil → liner
    assembly.add(makeConnector(3.08, 1.26 + capLift));  // liner → cap
    scene.add(assembly);

    // ---- OrbitControls -------------------------------------------------------
    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enablePan = false;
    controls.enableZoom = true;
    controls.minDistance = 5;
    controls.maxDistance = 18;
    controls.minPolarAngle = 0.2;
    controls.maxPolarAngle = Math.PI - 0.4;
    controls.autoRotate = true;
    controls.autoRotateSpeed = 0.9;
    controls.rotateSpeed = 0.7;
    controls.target.set(0.5, 0.8, 0);
    controls.update();

    let idleTimer: ReturnType<typeof setTimeout>;
    const resumeIdle = () => {
      clearTimeout(idleTimer);
      controls.autoRotate = false;
      idleTimer = setTimeout(() => (controls.autoRotate = true), 4000);
    };
    renderer.domElement.addEventListener("pointerdown", resumeIdle);
    renderer.domElement.addEventListener("wheel", resumeIdle);

    // ---- LABELS with arrows (toggleable) -------------------------------------
    // Each label is a fixed-position HTML card anchored at the container edge.
    // An SVG arrow connects the card to a tracked 3D point. As the camera rotates,
    // only the arrow endpoint moves (label stays anchored — easier to read).
    type LabelSide = "left" | "right";
    type LabelDef = { text: string; sub: string; target: THREE.Vector3; side: LabelSide; topPct: number };
    // Target points are in WORLD coordinates (assembly is offset by -1.0 on Y).
    const labelDefs: LabelDef[] = [
      { text: "Cap",                 sub: "tinplate, gold lacquer",      target: new THREE.Vector3(0.6, 1.85 + capLift - 1.0, 0), side: "left",  topPct: 5  },
      { text: "EPE foam liner",      sub: "Layer 1 · primary gasket",    target: new THREE.Vector3(0.4, 3.05 - 1.0, 0),           side: "right", topPct: 23 },
      { text: "Induction foil",      sub: "Layer 2 · airtight seal",     target: new THREE.Vector3(0.5, 2.30 - 1.0, 0),           side: "left",  topPct: 38 },
      { text: "GPI 63/2030 neck",    sub: "thread + sealing rim",        target: new THREE.Vector3(0.86, 1.45 - 1.0, 0),          side: "right", topPct: 54 },
      { text: "Glass body + label",  sub: "flint glass, hand-filled",    target: new THREE.Vector3(1.0, -0.4 - 1.0, 0),           side: "left",  topPct: 72 },
      { text: "Tamper band",         sub: "Layer 3 · 6mm joint seal",    target: new THREE.Vector3(2.3, 1.6 - 1.0, 0.4),          side: "right", topPct: 88 },
    ];

    const labelLayer = document.createElement("div");
    labelLayer.id = "seal-labels-layer";
    labelLayer.style.cssText = "position:absolute; inset:0; pointer-events:none; z-index:5;";
    container.appendChild(labelLayer);

    const arrowSvg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
    arrowSvg.style.cssText = "position:absolute; inset:0; width:100%; height:100%; pointer-events:none; overflow:visible;";
    labelLayer.appendChild(arrowSvg);

    // SVG <defs> for arrowhead marker
    const defs = document.createElementNS("http://www.w3.org/2000/svg", "defs");
    defs.innerHTML = `
      <marker id="seal-arrow-head" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#7a1f10"/>
      </marker>
    `;
    arrowSvg.appendChild(defs);

    type LabelInstance = { def: LabelDef; el: HTMLDivElement; line: SVGLineElement };
    const labels: LabelInstance[] = labelDefs.map((def) => {
      const el = document.createElement("div");
      el.className = `seal-label seal-label-${def.side}`;
      el.style.cssText = `position:absolute; ${def.side}:10px; top:${def.topPct}%; transform:translateY(-50%); pointer-events:none;`;
      el.innerHTML = `
        <div class="seal-label-card">
          <div class="seal-label-title">${def.text}</div>
          <div class="seal-label-sub">${def.sub}</div>
        </div>
      `;
      labelLayer.appendChild(el);

      const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
      line.setAttribute("stroke", "#7a1f10");
      line.setAttribute("stroke-width", "1.2");
      line.setAttribute("stroke-dasharray", "3 3");
      line.setAttribute("marker-end", "url(#seal-arrow-head)");
      arrowSvg.appendChild(line);

      return { def, el, line };
    });

    function updateLabels() {
      const cw = container!.clientWidth;
      const ch = container!.clientHeight;
      const cRect = container!.getBoundingClientRect();
      for (const { def, el, line } of labels) {
        // Project the 3D target point to 2D screen coords inside the container.
        const v = def.target.clone().project(camera);
        const x2 = (v.x + 1) / 2 * cw;
        const y2 = (1 - v.y) / 2 * ch;
        // Start point: inner edge of the label card.
        const r = el.getBoundingClientRect();
        const x1 = def.side === "left" ? (r.right - cRect.left) : (r.left - cRect.left);
        const y1 = (r.top + r.bottom) / 2 - cRect.top;
        line.setAttribute("x1", String(x1));
        line.setAttribute("y1", String(y1));
        line.setAttribute("x2", String(x2));
        line.setAttribute("y2", String(y2));
        // If the projected point is behind the camera, hide that arrow.
        const visible = v.z < 1;
        line.style.opacity = visible ? "0.7" : "0";
      }
    }

    // Toggle button wiring (the button is in the Astro markup)
    const toggleBtn = document.getElementById("seal-labels-toggle");
    let labelsVisible = true;
    if (toggleBtn) {
      toggleBtn.addEventListener("click", () => {
        labelsVisible = !labelsVisible;
        labelLayer.style.display = labelsVisible ? "" : "none";
        const txt = toggleBtn.querySelector("[data-label-text]");
        if (txt) txt.textContent = labelsVisible ? "Hide labels" : "Show labels";
      });
    }

    function tick() {
      controls.update();
      renderer.render(scene, camera);
      if (labelsVisible) updateLabels();
      requestAnimationFrame(tick);
    }
    tick();

    window.addEventListener("resize", () => {
      const w = container!.clientWidth;
      const h = container!.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    });
  }

  initSeal();
</script>

<style is:global>
  .seal-label-card {
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(122, 31, 16, 0.18);
    border-radius: 10px;
    padding: 6px 10px;
    font-family: "Inter", system-ui, sans-serif;
    backdrop-filter: blur(4px);
    box-shadow: 0 2px 8px rgba(42, 26, 16, 0.08);
    max-width: 160px;
  }
  .seal-label-title {
    font-size: 11px;
    font-weight: 600;
    color: #2a1a10;
    letter-spacing: 0.01em;
    line-height: 1.2;
  }
  .seal-label-sub {
    font-size: 9.5px;
    color: #2a1a10;
    opacity: 0.6;
    margin-top: 1px;
    line-height: 1.25;
  }
  @media (max-width: 720px) {
    .seal-label-card { max-width: 110px; padding: 4px 7px; }
    .seal-label-title { font-size: 10px; }
    .seal-label-sub { font-size: 8.5px; }
  }
</style>

