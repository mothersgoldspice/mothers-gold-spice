    <script is:inline>
      (function () {
        const PRESETS = {
          honest:   { brightness: 1.00, warmth: 0.50, env: 0.70, label: 0.25 },
          daylight: { brightness: 1.15, warmth: 0.15, env: 0.85, label: 0.45 },
          warm:     { brightness: 0.85, warmth: 0.90, env: 0.55, label: 0.30 },
          studio:   { brightness: 1.30, warmth: 0.40, env: 1.05, label: 0.70 },
        };

        const $ = (id) => document.getElementById(id);
        const sliders = {
          brightness: $("ctrl-brightness"),
          warmth: $("ctrl-warmth"),
          env: $("ctrl-env"),
          label: $("ctrl-label"),
        };
        const labels = {
          brightness: $("val-brightness"),
          warmth: $("val-warmth"),
          env: $("val-env"),
          label: $("val-label"),
        };

        function getSettings() {
          return {
            brightness: +sliders.brightness.value,
            warmth: +sliders.warmth.value,
            env: +sliders.env.value,
            label: +sliders.label.value,
          };
        }

        function updateValueLabels() {
          for (const k in labels) {
            labels[k].textContent = (+sliders[k].value).toFixed(2);
          }
        }

        function applyPresetValues(p) {
          sliders.brightness.value = p.brightness;
          sliders.warmth.value = p.warmth;
          sliders.env.value = p.env;
          sliders.label.value = p.label;
          updateValueLabels();
        }

        function highlightPreset(name) {
          document.querySelectorAll(".lighting-preset").forEach((b) => b.classList.remove("active"));
          if (name) {
            const btn = document.querySelector('[data-preset="' + name + '"]');
            if (btn) btn.classList.add("active");
          }
        }

        function emit() {
          const settings = getSettings();
          window.mgsLighting = settings;
          window.dispatchEvent(new CustomEvent("mgs-lighting-change", { detail: settings }));
          try { localStorage.setItem("mgs-lighting", JSON.stringify(settings)); } catch (e) {}
        }

        // Restore saved settings (or default to "honest")
        let activePreset = "honest";
        try {
          const saved = JSON.parse(localStorage.getItem("mgs-lighting") || "null");
          if (saved && typeof saved === "object") {
            applyPresetValues(saved);
            // Match preset if saved values exactly equal any preset
            activePreset = Object.keys(PRESETS).find((k) => {
              const p = PRESETS[k];
              return ["brightness", "warmth", "env", "label"].every((f) => Math.abs(p[f] - saved[f]) < 0.01);
            }) || null;
          } else {
            applyPresetValues(PRESETS.honest);
          }
        } catch (e) {
          applyPresetValues(PRESETS.honest);
        }

        // Wire up presets
        document.querySelectorAll(".lighting-preset").forEach((btn) => {
          btn.addEventListener("click", () => {
            const preset = btn.dataset.preset;
            applyPresetValues(PRESETS[preset]);
            highlightPreset(preset);
            emit();
          });
        });

        // Wire up sliders — fine-tuning clears the active preset highlight
        Object.values(sliders).forEach((s) => {
          s.addEventListener("input", () => {
            updateValueLabels();
            const cur = getSettings();
            const match = Object.keys(PRESETS).find((k) => {
              const p = PRESETS[k];
              return ["brightness", "warmth", "env", "label"].every((f) => Math.abs(p[f] - cur[f]) < 0.01);
            });
            highlightPreset(match || null);
            emit();
          });
        });

        highlightPreset(activePreset);
        // Publish initial state for any 3D scene that's already initialised
        window.mgsLighting = getSettings();
        window.dispatchEvent(new CustomEvent("mgs-lighting-change", { detail: window.mgsLighting }));
      })();
    </script>

