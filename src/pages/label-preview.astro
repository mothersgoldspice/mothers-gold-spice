    <script is:inline>
      (function () {
        const PRESETS = {
          honest:   { brightness: 1.00, warmth: 0.50, env: 0.70, label: 0.25, exposure: 1.00 },
          daylight: { brightness: 1.15, warmth: 0.15, env: 0.85, label: 0.45, exposure: 1.05 },
          warm:     { brightness: 0.85, warmth: 0.90, env: 0.55, label: 0.30, exposure: 0.95 },
          studio:   { brightness: 1.30, warmth: 0.40, env: 1.05, label: 0.70, exposure: 1.15 },
        };

        const $ = (id) => document.getElementById(id);
        const sliders = {
          brightness: $("ctrl-brightness"),
          warmth: $("ctrl-warmth"),
          env: $("ctrl-env"),
          label: $("ctrl-label"),
          exposure: $("ctrl-exposure"),
        };
        const labels = {
          brightness: $("val-brightness"),
          warmth: $("val-warmth"),
          env: $("val-env"),
          label: $("val-label"),
          exposure: $("val-exposure"),
        };

        const LIGHT_KEYS = ["key", "fill", "rim", "ambient", "hemi", "envmap"];
        function getToggles() {
          const out = {};
          LIGHT_KEYS.forEach((k) => {
            const cb = document.querySelector('[data-light="' + k + '"]');
            out[k] = cb ? cb.checked : true;
          });
          return out;
        }

        function setToggles(t) {
          LIGHT_KEYS.forEach((k) => {
            const cb = document.querySelector('[data-light="' + k + '"]');
            if (cb && typeof t[k] === "boolean") cb.checked = t[k];
          });
        }

        function getSettings() {
          return {
            brightness: +sliders.brightness.value,
            warmth: +sliders.warmth.value,
            env: +sliders.env.value,
            label: +sliders.label.value,
            exposure: +sliders.exposure.value,
            lights: getToggles(),
          };
        }

        function updateValueLabels() {
          for (const k in labels) {
            labels[k].textContent = (+sliders[k].value).toFixed(2);
          }
        }

        function applyPresetValues(p) {
          sliders.brightness.value = p.brightness;
          sliders.warmth.value = p.warmth;
          sliders.env.value = p.env;
          sliders.label.value = p.label;
          if (typeof p.exposure === "number") sliders.exposure.value = p.exposure;
          updateValueLabels();
        }

        function highlightPreset(name) {
          document.querySelectorAll(".lighting-preset").forEach((b) => b.classList.remove("active"));
          if (name) {
            const btn = document.querySelector('[data-preset="' + name + '"]');
            if (btn) btn.classList.add("active");
          }
        }

        function emit() {
          const settings = getSettings();
          window.mgsLighting = settings;
          window.dispatchEvent(new CustomEvent("mgs-lighting-change", { detail: settings }));
          try { localStorage.setItem("mgs-lighting", JSON.stringify(settings)); } catch (e) {}
        }

        // Restore saved settings (or default to "honest")
        let activePreset = "honest";
        try {
          const saved = JSON.parse(localStorage.getItem("mgs-lighting") || "null");
          if (saved && typeof saved === "object") {
            applyPresetValues(saved);
            if (saved.lights) setToggles(saved.lights);
            // Match preset if saved values exactly equal any preset
            activePreset = Object.keys(PRESETS).find((k) => {
              const p = PRESETS[k];
              return ["brightness", "warmth", "env", "label", "exposure"].every((f) => Math.abs(p[f] - (saved[f] ?? p[f])) < 0.01);
            }) || null;
          } else {
            applyPresetValues(PRESETS.honest);
          }
        } catch (e) {
          applyPresetValues(PRESETS.honest);
        }

        // Wire up presets
        document.querySelectorAll(".lighting-preset").forEach((btn) => {
          btn.addEventListener("click", () => {
            const preset = btn.dataset.preset;
            applyPresetValues(PRESETS[preset]);
            highlightPreset(preset);
            emit();
          });
        });

        // Wire up sliders — fine-tuning clears the active preset highlight
        Object.values(sliders).forEach((s) => {
          s.addEventListener("input", () => {
            updateValueLabels();
            const cur = getSettings();
            const match = Object.keys(PRESETS).find((k) => {
              const p = PRESETS[k];
              return ["brightness", "warmth", "env", "label", "exposure"].every((f) => Math.abs(p[f] - cur[f]) < 0.01);
            });
            highlightPreset(match || null);
            emit();
          });
        });

        // Wire up light-source toggle checkboxes
        document.querySelectorAll("[data-light]").forEach((cb) => {
          cb.addEventListener("change", () => emit());
        });

        highlightPreset(activePreset);
        // Publish initial state for any 3D scene that's already initialised
        window.mgsLighting = getSettings();
        window.dispatchEvent(new CustomEvent("mgs-lighting-change", { detail: window.mgsLighting }));
      })();

      // ---------- Immersive (full-screen) mode for 3D viewers ----------
      (function () {
        let activeContainer = null;
        let exitBtn = null;

        function exitImmersive() {
          if (!activeContainer) return;
          activeContainer.classList.remove("mgs-immersive");
          var wrap = activeContainer.parentElement;
          if (wrap) wrap.classList.remove("mgs-immersive-wrap");
          document.body.classList.remove("mgs-immersive-active");
          if (exitBtn && exitBtn.parentNode) exitBtn.parentNode.removeChild(exitBtn);
          exitBtn = null;
          activeContainer = null;
          window.dispatchEvent(new Event("resize"));
        }

        function enterImmersive(targetId) {
          var el = document.getElementById(targetId);
          if (!el) return;
          activeContainer = el;
          el.classList.add("mgs-immersive");
          var wrap = el.parentElement;
          if (wrap) wrap.classList.add("mgs-immersive-wrap");
          document.body.classList.add("mgs-immersive-active");

          exitBtn = document.createElement("button");
          exitBtn.type = "button";
          exitBtn.className = "mgs-immersive-exit";
          exitBtn.innerHTML = '<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 4 L12 12 M12 4 L4 12"/></svg> Exit (ESC)';
          exitBtn.addEventListener("click", exitImmersive);
          document.body.appendChild(exitBtn);

          window.dispatchEvent(new Event("resize"));
        }

        // Bind via event delegation so it works whenever DOM is ready
        document.addEventListener("click", function (e) {
          var btn = e.target && e.target.closest && e.target.closest("[data-immersive-target]");
          if (!btn) return;
          e.stopPropagation();
          enterImmersive(btn.getAttribute("data-immersive-target"));
        });

        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape" && activeContainer) exitImmersive();
        });
      })();
    </script>

