        <div class="p-5 bg-white rounded-xl border border-ink/5">
          <p class="text-xs uppercase tracking-widest text-spice-500 font-medium mb-2">Across SKUs</p>
          <p>Lime, Mixed Veg, Garlic, etc. will reuse this exact layout — only the product name, ingredients list, and nutritional table change. Back-panel info block stays identical.</p>
        </div>
      </div>

      <div class="mt-12 p-6 bg-spice-700/5 border-l-4 border-spice-700 rounded">
        <p class="font-serif text-spice-700 font-semibold mb-2">Next steps</p>
        <ol class="text-sm text-ink/80 list-decimal pl-5 space-y-1.5">
          <li>Get FSSAI registration → real license number replaces placeholder.</li>
          <li>NABL lab nutritional analysis → real numbers replace estimates.</li>
          <li>Decide final MRP (after filling <code>PRICING.md</code>).</li>
          <li>Print shop: get quotes at 500 / 1,000 / 5,000 labels for this size.</li>
          <li>Order a wet proof (one physical print) before any bulk run.</li>
          <li>Apply to a 250g sample jar, photograph it, replace website Hero with real labeled jar.</li>
        </ol>
      </div>
    </section>
  </main>
</Layout>

<script>
  import * as THREE from "three";
  import { OrbitControls } from "three/addons/controls/OrbitControls.js";
  import { RoomEnvironment } from "three/addons/environments/RoomEnvironment.js";

  // --- v2 cap-top decal (matches section 4 design exactly) ---
  const jarCapDecalSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" width="500" height="500">
