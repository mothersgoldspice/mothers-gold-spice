      <g transform="translate(360, 124)">
        <line x1="-52" y1="0" x2="-14" y2="0" stroke="#e08712" stroke-width="1.5"/>
        <path d="M 0 -7 C 5 -3 5 4 0 7 C -5 4 -5 -3 0 -7 Z" fill="#e08712"/>
        <line x1="14" y1="0" x2="52" y2="0" stroke="#e08712" stroke-width="1.5"/>
