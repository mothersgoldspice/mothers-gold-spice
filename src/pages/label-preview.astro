      <text x="360" y="186" text-anchor="middle" font-family="'Fraunces', Georgia, serif" font-weight="600" font-size="56" fill="#7a1f10">Mango Pickle</text>

      <text x="360" y="214" text-anchor="middle" font-family="'Fraunces', Georgia, serif" font-style="italic" font-size="20" fill="#2a1a10" fill-opacity="0.7">in Mustard Oil</text>

      <g transform="translate(360, 250)">
        <line x1="-170" y1="-13" x2="170" y2="-13" stroke="#7a1f10" stroke-opacity="0.3" stroke-width="1"/>
        <line x1="-170" y1="13" x2="170" y2="13" stroke="#7a1f10" stroke-opacity="0.3" stroke-width="1"/>
        <text x="-80" y="5" text-anchor="middle" font-weight="600" font-size="11" letter-spacing="1.8" fill="#7a1f10">NO PRESERVATIVES</text>
        <text x="0" y="5" text-anchor="middle" font-size="14" fill="#7a1f10" fill-opacity="0.4">·</text>
        <text x="80" y="5" text-anchor="middle" font-weight="600" font-size="11" letter-spacing="1.8" fill="#7a1f10">NO ADDITIVES</text>
      </g>

      <!-- Bottom row: NET WT | VEG | MRP, packed tight around centre x = 360 -->
      <g transform="translate(360, 318)">
        <g transform="translate(-115, 0)">
          <text x="0" y="0" text-anchor="middle" font-size="10" letter-spacing="1.2" fill="#7a1f10" font-weight="600">NET WT.</text>
          <text x="0" y="22" text-anchor="middle" font-family="'Fraunces', Georgia, serif" font-weight="600" font-size="22" fill="#2a1a10">250g</text>
        </g>

        <rect x="-17" y="-10" width="34" height="34" fill="none" stroke="#1e7a1e" stroke-width="2.2"/>
        <circle cx="0" cy="7" r="10" fill="#1e7a1e"/>

        <g transform="translate(115, 0)">
          <text x="0" y="0" text-anchor="middle" font-size="10" letter-spacing="1.2" fill="#7a1f10" font-weight="600">MRP</text>
          <text x="0" y="22" text-anchor="middle" font-family="'Fraunces', Georgia, serif" font-weight="600" font-size="22" fill="#2a1a10">₹449</text>
        </g>
      </g>
    </g>
  </svg>`;

  async function init() {
    await document.fonts.ready;

    const container = document.getElementById("jar3d-container");
    if (!container) return;

    const w = container.clientWidth;
    const h = container.clientHeight;

    const scene = new THREE.Scene();
    scene.background = null;

    const camera = new THREE.PerspectiveCamera(30, w / h, 0.1, 100);
    camera.position.set(0, 0.5, 9);

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(w, h);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    container.appendChild(renderer.domElement);

    // Environment map for realistic metal/glass reflections
    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

    // Lighting — kept as references so the lighting control panel can update them live
    const ambient = new THREE.AmbientLight(0xffffff, 0.4);
    scene.add(ambient);
    const key = new THREE.DirectionalLight(0xffffff, 0.9);
    key.position.set(3, 4, 5);
    scene.add(key);
    const fill = new THREE.DirectionalLight(0xfff4d6, 0.35);
    fill.position.set(-3, 1, -3);
    scene.add(fill);
    const rim = new THREE.DirectionalLight(0xffffff, 0.3);
    rim.position.set(0, 2, -4);
    scene.add(rim);

    // Materials we'll mutate from the control panel
    let glassMat: THREE.MeshPhysicalMaterial | null = null;
    let labelMat: THREE.MeshStandardMaterial | null = null;
    let goldMat: THREE.MeshStandardMaterial | null = null;

    // Base values — what gets multiplied by the "brightness" slider
    const BASE = { ambient: 0.4, key: 0.9, fill: 0.35, rim: 0.3 };
    const COOL = new THREE.Color(0xffffff);
    const WARM = new THREE.Color(0xffd5a0);
    const FILL_COOL = new THREE.Color(0xfff4d6);
    const FILL_WARM = new THREE.Color(0xffc78a);

    function applyLighting(s: any) {
      if (!s) return;
      const tint = COOL.clone().lerp(WARM, s.warmth);
      const fillTint = FILL_COOL.clone().lerp(FILL_WARM, s.warmth);
      ambient.intensity = BASE.ambient * s.brightness;
      ambient.color.copy(tint);
      key.intensity = BASE.key * s.brightness;
      key.color.copy(tint);
      fill.intensity = BASE.fill * s.brightness;
      fill.color.copy(fillTint);
      rim.intensity = BASE.rim * s.brightness;
      rim.color.copy(tint);
      if (glassMat) glassMat.envMapIntensity = s.env;
      if (goldMat) goldMat.envMapIntensity = s.env;
      if (labelMat) labelMat.envMapIntensity = s.label;
    }

    window.addEventListener("mgs-lighting-change", (e: any) => applyLighting(e.detail));

    // Generate label texture from SVG
    const dataUrl = "data:image/svg+xml;charset=utf-8," + encodeURIComponent(labelSvg);
    const img = new Image();
    img.crossOrigin = "anonymous";

    img.onload = () => {
      const canvas = document.createElement("canvas");
      canvas.width = 2880; // 2x upscale of viewBox for sharpness
      canvas.height = 720;
      const ctx = canvas.getContext("2d");
      if (!ctx) return;
      ctx.fillStyle = "#fbf6ec";
      ctx.fillRect(0, 0, 2880, 720);
      ctx.drawImage(img, 0, 0, 2880, 720);

      const labelTexture = new THREE.CanvasTexture(canvas);
      labelTexture.colorSpace = THREE.SRGBColorSpace;
      labelTexture.anisotropy = renderer.capabilities.getMaxAnisotropy();
      labelTexture.wrapS = THREE.RepeatWrapping;
      // Front-panel center sits at texture u = 0.75. Cylinder u = 0 is the +Z (camera-
      // facing) side. offset.x = 0.75 lands the front centre directly facing the camera.
      labelTexture.offset.set(0.75, 0);

      buildJar(labelTexture);
    };

    img.onerror = (err) => {
      console.error("Label texture load failed", err);
    };

    img.src = dataUrl;

    let controls: any = null;

    function buildJar(labelTexture: THREE.CanvasTexture) {
      const jar = new THREE.Group();

      // Clear glass body — high transmission, low roughness, slight warm tint
      glassMat = new THREE.MeshPhysicalMaterial({
        color: 0xfffaf0,
        roughness: 0.05,
        metalness: 0,
        transmission: 1.0,
        thickness: 0.4,
        ior: 1.5,
        transparent: true,
        opacity: 1,
        side: THREE.DoubleSide,
        clearcoat: 0.4,
        clearcoatRoughness: 0.1,
      });

      // Body profile (lathed around Y axis): rounded base, straight panel, shoulder taper to neck.
      // Profile starts at the axis at the bottom and ends near the axis at the top (covered by cap).
      const bodyProfile = [
        new THREE.Vector2(0, -1.30),     // bottom centre (closed)
        new THREE.Vector2(0.80, -1.30),  // flat base
        new THREE.Vector2(0.90, -1.28),  // base bevel ↗
        new THREE.Vector2(0.96, -1.25),
        new THREE.Vector2(1.00, -1.20),  // body widest
        new THREE.Vector2(1.00, 1.05),   // straight body
        new THREE.Vector2(0.97, 1.13),   // shoulder bevel ↗
        new THREE.Vector2(0.92, 1.20),
        new THREE.Vector2(0.86, 1.25),   // neck taper
        new THREE.Vector2(0.85, 1.28),   // neck (hidden by cap)
      ];
      const body = new THREE.Mesh(new THREE.LatheGeometry(bodyProfile, 96), glassMat);
      jar.add(body);

      // Label wrap — thin cylinder on the straight body panel.
      // envMapIntensity is dialled down so the paper doesn't pick up metal-like reflections.
      labelMat = new THREE.MeshStandardMaterial({
        map: labelTexture,
        side: THREE.DoubleSide,
        roughness: 0.85,
        metalness: 0,
        envMapIntensity: 0.25,
      });
      const labelMesh = new THREE.Mesh(
        new THREE.CylinderGeometry(1.018, 1.018, 1.55, 128, 1, true),
        labelMat
      );
      labelMesh.position.y = -0.05;
      jar.add(labelMesh);

      // Warm champagne-gold tinplate cap (matte/satin finish — not mirror chrome).
      // DoubleSide makes the top disc render no matter which way LatheGeometry winds it.
      goldMat = new THREE.MeshStandardMaterial({
        color: 0xc9a96e,
        roughness: 0.42,
        metalness: 0.85,
        side: THREE.DoubleSide,
      });
      const capProfile = [
        new THREE.Vector2(0, 1.85),
        new THREE.Vector2(0.85, 1.85),    // top flat
        new THREE.Vector2(0.91, 1.83),    // top bevel ↘
        new THREE.Vector2(0.95, 1.79),
        new THREE.Vector2(0.96, 1.74),
        new THREE.Vector2(0.96, 1.32),    // cap straight side
        new THREE.Vector2(0.93, 1.30),    // tiny bottom bevel
        new THREE.Vector2(0.86, 1.30),    // close to neck radius
      ];
      const cap = new THREE.Mesh(new THREE.LatheGeometry(capProfile, 64), goldMat);
      jar.add(cap);

      jar.position.y = -0.25;
      scene.add(jar);

      // Apply current lighting now that the materials exist
      if ((window as any).mgsLighting) applyLighting((window as any).mgsLighting);

      controls = new OrbitControls(camera, renderer.domElement);
      controls.enablePan = false;
      controls.enableZoom = false;
      controls.minPolarAngle = Math.PI / 2.4;
      controls.maxPolarAngle = Math.PI / 1.7;
      controls.autoRotate = true;
      controls.autoRotateSpeed = 1.2;
      controls.rotateSpeed = 0.7;
      controls.target.set(0, 0, 0);
      controls.update();

      // Stop auto-rotate on user interaction; resume after idle
      let idleTimer: ReturnType<typeof setTimeout>;
      const resetIdle = () => {
        if (controls) controls.autoRotate = false;
        clearTimeout(idleTimer);
        idleTimer = setTimeout(() => {
          if (controls) controls.autoRotate = true;
        }, 2500);
      };
      controls.addEventListener("start", resetIdle);
    }

    function animate() {
      requestAnimationFrame(animate);
      if (controls) controls.update();
      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener("resize", () => {
      const w = container.clientWidth;
      const h = container.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    });
  }

  init();
</script>

<script>
  // ============================================================
  // Cap-only preview (section 4) — gold cap with v2 brand mark
  // ============================================================
  import * as THREE from "three";
  import { OrbitControls } from "three/addons/controls/OrbitControls.js";
  import { RoomEnvironment } from "three/addons/environments/RoomEnvironment.js";

  // Brand-mark SVG that would be foil-stamped on the cap top.
  // Spice-red foil on gold tinplate.
  const capDecalSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" width="500" height="500">
    <defs>
      <path id="capTopArc" d="M 90,265 A 160,160 0 0 1 410,265" fill="none"/>
    </defs>

    <!-- Outer ring -->
    <circle cx="250" cy="250" r="225" fill="none" stroke="#7a1f10" stroke-width="1" stroke-opacity="0.5"/>
    <circle cx="250" cy="250" r="218" fill="none" stroke="#7a1f10" stroke-width="0.6" stroke-opacity="0.35"/>

    <!-- Top arched: italic serif wordmark -->
    <text font-family="'Fraunces', Georgia, serif" font-style="italic" font-size="34" font-weight="600" fill="#7a1f10">
      <textPath href="#capTopArc" startOffset="50%" text-anchor="middle">Mother's Gold Spice</textPath>
    </text>

    <!-- Divider with mango motif -->
    <g transform="translate(250, 290)">
      <line x1="-46" y1="0" x2="-14" y2="0" stroke="#7a1f10" stroke-width="1.4"/>
      <path d="M 0,-7 C 5,-3 5,4 0,7 C -5,4 -5,-3 0,-7 Z" fill="#7a1f10"/>
      <line x1="14" y1="0" x2="46" y2="0" stroke="#7a1f10" stroke-width="1.4"/>
    </g>

    <!-- Centre mango with leaf -->
    <g transform="translate(250, 340)" fill="#7a1f10">
      <path d="M 0,-22 C 16,-11 16,12 0,32 C -16,12 -16,-11 0,-22 Z"/>
      <path d="M 6,-22 C 14,-31 24,-29 27,-21 C 22,-25 14,-25 10,-19 Z"/>
      <line x1="3" y1="-22" x2="6" y2="-28" stroke="#7a1f10" stroke-width="1.4"/>
    </g>

    <!-- Bottom: tagline -->
    <text x="250" y="408" text-anchor="middle" font-family="'Inter', sans-serif" font-size="13" font-weight="600" letter-spacing="3.2" fill="#7a1f10">HAND-MADE IN BANGALORE</text>

    <!-- Decorative dots -->
    <circle cx="250" cy="92" r="2.5" fill="#7a1f10"/>
    <circle cx="80" cy="250" r="1.8" fill="#7a1f10"/>
    <circle cx="420" cy="250" r="1.8" fill="#7a1f10"/>
  </svg>`;

  async function initCap() {
    await document.fonts.ready;

    const container = document.getElementById("cap3d-container");
    if (!container) return;

    const w = container.clientWidth;
    const h = container.clientHeight;

    const scene = new THREE.Scene();
    scene.background = null;

    const camera = new THREE.PerspectiveCamera(32, w / h, 0.1, 100);
    camera.position.set(0, 3.2, 3.6);

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(w, h);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    container.appendChild(renderer.domElement);

    // Environment map gives the gold metal proper reflections from every angle
    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

    // Lighting — kept as references so the control panel can update them live
    const ambient = new THREE.AmbientLight(0xffffff, 0.3);
    scene.add(ambient);
    const key = new THREE.DirectionalLight(0xffffff, 0.9);
    key.position.set(3, 5, 4);
    scene.add(key);
    const fill = new THREE.DirectionalLight(0xfff4d6, 0.35);
    fill.position.set(-3, 2, -2);
    scene.add(fill);
    const rim = new THREE.DirectionalLight(0xffe5b8, 0.3);
    rim.position.set(0, -1, -3);
    scene.add(rim);

    let goldMat: THREE.MeshStandardMaterial | null = null;

    const BASE = { ambient: 0.3, key: 0.9, fill: 0.35, rim: 0.3 };
    const COOL = new THREE.Color(0xffffff);
    const WARM = new THREE.Color(0xffd5a0);
    const FILL_COOL = new THREE.Color(0xfff4d6);
    const FILL_WARM = new THREE.Color(0xffc78a);

    function applyLighting(s: any) {
      if (!s) return;
      const tint = COOL.clone().lerp(WARM, s.warmth);
      const fillTint = FILL_COOL.clone().lerp(FILL_WARM, s.warmth);
      ambient.intensity = BASE.ambient * s.brightness;
      ambient.color.copy(tint);
      key.intensity = BASE.key * s.brightness;
      key.color.copy(tint);
      fill.intensity = BASE.fill * s.brightness;
      fill.color.copy(fillTint);
      rim.intensity = BASE.rim * s.brightness;
      rim.color.copy(tint);
      if (goldMat) goldMat.envMapIntensity = s.env;
    }

    window.addEventListener("mgs-lighting-change", (e: any) => applyLighting(e.detail));

    const dataUrl = "data:image/svg+xml;charset=utf-8," + encodeURIComponent(capDecalSvg);
    const img = new Image();
    img.crossOrigin = "anonymous";

    img.onload = () => {
      const canvas = document.createElement("canvas");
      canvas.width = 1024;
      canvas.height = 1024;
      const ctx = canvas.getContext("2d");
      if (!ctx) return;
      ctx.clearRect(0, 0, 1024, 1024);
      ctx.drawImage(img, 0, 0, 1024, 1024);

      const decalTexture = new THREE.CanvasTexture(canvas);
      decalTexture.colorSpace = THREE.SRGBColorSpace;
      decalTexture.anisotropy = renderer.capabilities.getMaxAnisotropy();

      buildCap(decalTexture);
    };
    img.onerror = (err) => console.error("Cap decal load failed", err);
    img.src = dataUrl;

    let controls: any = null;

    function buildCap(decalTex: THREE.CanvasTexture) {
      const group = new THREE.Group();

      // Same gold material as the jar's cap. DoubleSide so the top disc renders properly.
      goldMat = new THREE.MeshStandardMaterial({
        color: 0xc9a96e,
        roughness: 0.42,
        metalness: 0.85,
        side: THREE.DoubleSide,
      });

      // Same lathed cap profile as the main jar (softly rounded top edge)
      const capProfile = [
        new THREE.Vector2(0, 1.85),
        new THREE.Vector2(0.85, 1.85),
        new THREE.Vector2(0.91, 1.83),
        new THREE.Vector2(0.95, 1.79),
        new THREE.Vector2(0.96, 1.74),
        new THREE.Vector2(0.96, 1.32),
        new THREE.Vector2(0.93, 1.30),
        new THREE.Vector2(0.86, 1.30),
      ];
      const cap = new THREE.Mesh(new THREE.LatheGeometry(capProfile, 96), goldMat);
      group.add(cap);

      // Brand-mark decal disc — sits just above the cap top to avoid z-fighting
      const decalMat = new THREE.MeshStandardMaterial({
        map: decalTex,
        transparent: true,
        alphaTest: 0.02,
        roughness: 0.4,
        metalness: 0.6,
        side: THREE.DoubleSide,
      });
      const decal = new THREE.Mesh(new THREE.CircleGeometry(0.78, 96), decalMat);
      decal.rotation.x = -Math.PI / 2;
      decal.position.y = 1.851;
      group.add(decal);

      // Centre the group near the camera's target
      group.position.y = -1.55;
      scene.add(group);

      // Apply current lighting now that the material exists
      if ((window as any).mgsLighting) applyLighting((window as any).mgsLighting);

      controls = new OrbitControls(camera, renderer.domElement);
      controls.enablePan = false;
      controls.enableZoom = false;
      controls.minPolarAngle = Math.PI / 6;
      controls.maxPolarAngle = Math.PI / 2.1;
      controls.autoRotate = true;
      controls.autoRotateSpeed = 1.4;
      controls.rotateSpeed = 0.7;
      controls.target.set(0, 0, 0);
      controls.update();

      let idleTimer: ReturnType<typeof setTimeout>;
      const resetIdle = () => {
        if (controls) controls.autoRotate = false;
        clearTimeout(idleTimer);
        idleTimer = setTimeout(() => {
          if (controls) controls.autoRotate = true;
        }, 2500);
      };
      controls.addEventListener("start", resetIdle);
    }

    function animate() {
      requestAnimationFrame(animate);
      if (controls) controls.update();
      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener("resize", () => {
      const w = container.clientWidth;
      const h = container.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    });
  }

  initCap();
</script>
